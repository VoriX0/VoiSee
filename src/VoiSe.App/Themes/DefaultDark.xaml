<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Built-in VoiSee 10 Default Dark semantic contract. -->
    <SolidColorBrush x:Key="VoiSee.AppBackgroundBrush" Color="#FF000000" />
    <SolidColorBrush x:Key="VoiSee.TitleBarBackgroundBrush" Color="#FF000000" />
    <SolidColorBrush x:Key="VoiSee.TitleBarForegroundBrush" Color="#FFFFFFFF" />
    <SolidColorBrush x:Key="VoiSee.TitleBarHoverBrush" Color="#FF202020" />
    <SolidColorBrush x:Key="VoiSee.TitleBarPressedBrush" Color="#FF101010" />

    <SolidColorBrush x:Key="VoiSee.PanelBackgroundBrush" Color="#08000000" />
    <SolidColorBrush x:Key="VoiSee.PanelBorderBrush" Color="#22FFFFFF" />
    <SolidColorBrush x:Key="VoiSee.PrimaryTextBrush" Color="#FFFFFFFF" />
    <SolidColorBrush x:Key="VoiSee.SecondaryTextBrush" Color="#B8FFFFFF" />
    <SolidColorBrush x:Key="VoiSee.AccentBrush" Color="#FF60CDFF" />
    <SolidColorBrush x:Key="VoiSee.DangerBrush" Color="#FFFF4D4D" />
    <SolidColorBrush x:Key="VoiSee.SuccessBrush" Color="#FF37D67A" />
    <SolidColorBrush x:Key="VoiSee.WarningBrush" Color="#FFFFD166" />

    <SolidColorBrush x:Key="VoiSee.ButtonBackgroundBrush" Color="#12FFFFFF" />
    <SolidColorBrush x:Key="VoiSee.ButtonHoverBrush" Color="#20FFFFFF" />
    <SolidColorBrush x:Key="VoiSee.ButtonPressedBrush" Color="#0CFFFFFF" />
    <SolidColorBrush x:Key="VoiSee.ButtonBorderBrush" Color="#22FFFFFF" />
    <SolidColorBrush x:Key="VoiSee.InputBackgroundBrush" Color="#0AFFFFFF" />

    <SolidColorBrush x:Key="VoiSee.TimelineHostBrush" Color="#01000000" />
    <SolidColorBrush x:Key="VoiSee.TransparentHitTestBrush" Color="#01000000" />
    <SolidColorBrush x:Key="VoiSee.TimelineTrackBrush" Color="#33FFFFFF" />
    <SolidColorBrush x:Key="VoiSee.TimelineFillBrush" Color="#99FFFFFF" />
    <SolidColorBrush x:Key="VoiSee.TimelineThumbBrush" Color="#FFFFFFFF" />
    <SolidColorBrush x:Key="VoiSee.MuteBannerBackgroundBrush" Color="#44220000" />
    <SolidColorBrush x:Key="VoiSee.MuteBannerBorderBrush" Color="#88FF4D4D" />
    <SolidColorBrush x:Key="VoiSee.DropOverlayBackgroundBrush" Color="#E0202020" />
    <SolidColorBrush x:Key="VoiSee.DropOverlayBorderBrush" Color="#66FFFFFF" />
    <SolidColorBrush x:Key="VoiSee.DropOverlayInnerBackgroundBrush" Color="#DD202020" />
    <SolidColorBrush x:Key="VoiSee.DropOverlayInnerBorderBrush" Color="#55FFFFFF" />
    <SolidColorBrush x:Key="VoiSee.CardValueBackgroundBrush" Color="#22FFFFFF" />
    <SolidColorBrush x:Key="VoiSee.CardValueBorderBrush" Color="#44FFFFFF" />
    <SolidColorBrush x:Key="VoiSee.VBCableNoticeBackgroundBrush" Color="#22141414" />
    <SolidColorBrush x:Key="VoiSee.VBCableNoticeBorderBrush" Color="#55D68B00" />

    <CornerRadius x:Key="VoiSee.CornerRadius.Small">4</CornerRadius>
    <CornerRadius x:Key="VoiSee.CornerRadius.Medium">10</CornerRadius>
    <CornerRadius x:Key="VoiSee.CornerRadius.Large">12</CornerRadius>

    <!-- Standard WinUI resources can also be overridden by user dictionaries. -->
    <SolidColorBrush x:Key="ApplicationPageBackgroundThemeBrush" Color="#FF000000" />
    <SolidColorBrush x:Key="TextFillColorPrimaryBrush" Color="#FFFFFFFF" />
    <SolidColorBrush x:Key="TextFillColorSecondaryBrush" Color="#B8FFFFFF" />
    <SolidColorBrush x:Key="AccentFillColorDefaultBrush" Color="#FF60CDFF" />

</ResourceDictionary>
