<Window
    x:Class="VoiSe.App.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:VoiSe.App"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="VoiSee Version 11.0.0">

    <Grid x:Name="RootGrid" RequestedTheme="Dark" Background="{ThemeResource VoiSee.AppBackgroundBrush}" SizeChanged="OnRootGridSizeChanged">
        <Grid.RowDefinitions>
            <RowDefinition Height="32" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid x:Name="CustomTitleBar" Grid.Row="0" Background="{ThemeResource VoiSee.TitleBarBackgroundBrush}" Height="32" VerticalAlignment="Top">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="138" />
            </Grid.ColumnDefinitions>
            <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center" Margin="10,0,0,0">
                <Image Source="ms-appx:///Assets/AppIcon_24.png" Width="16" Height="16" VerticalAlignment="Center" />
                <TextBlock x:Name="TitleBarVersionTextBlock" Text="VoiSee Version 11.0.0" FontSize="12" Foreground="{ThemeResource VoiSee.PrimaryTextBrush}" VerticalAlignment="Center" />
            </StackPanel>
        </Grid>

        <Grid Grid.Row="1" Padding="20" RowSpacing="14">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

        <Border Style="{ThemeResource VoiSee.Style.Panel.MainHeader}" x:Name="MainHeaderBorder" Grid.Row="0" Padding="6" MinHeight="46">
            <Grid ColumnSpacing="16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                    <Image Source="ms-appx:///Assets/AppIcon_48.png" Width="34" Height="34" VerticalAlignment="Center" />
                    <TextBlock x:Name="MainTitle" Text="VoiSee Version 11.0.0" FontSize="28" FontWeight="SemiBold" Foreground="{ThemeResource VoiSee.PrimaryTextBrush}" VerticalAlignment="Center" />
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="10" VerticalAlignment="Center" HorizontalAlignment="Right">
                    <TextBlock Text="Mic Output" Foreground="{ThemeResource VoiSee.PrimaryTextBrush}" Opacity="0.62" VerticalAlignment="Center" />
                    <TextBlock x:Name="VirtualMicMuteStatusTextBlock" Text="Live" Foreground="{ThemeResource VoiSee.SuccessBrush}" Opacity="0.95" FontWeight="SemiBold" VerticalAlignment="Center" />
                    <Button Style="{ThemeResource VoiSee.Style.Button.VirtualMicMute}" x:Name="VirtualMicMuteToggleButton" Content="Mute" MinWidth="92" Padding="10,4" Click="OnVirtualMicMuteToggleClick" />
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1" x:Name="MainContentHost" RowSpacing="8">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <Border x:Name="VirtualMicMutedBanner" Grid.Row="0" Background="{ThemeResource VoiSee.MuteBannerBackgroundBrush}" BorderBrush="{ThemeResource VoiSee.MuteBannerBorderBrush}" BorderThickness="1" CornerRadius="{ThemeResource VoiSee.CornerRadius.Medium}" Padding="12,8" Visibility="Collapsed">
                <TextBlock Text="Virtual mic output is muted. You can still hear VoiSee in headphones, but Discord/OBS/games receive silence." Foreground="{ThemeResource VoiSee.PrimaryTextBrush}" FontWeight="SemiBold" TextWrapping="WrapWholeWords" />
            </Border>
            <Border x:Name="MainTabHostBorder" Grid.Row="1" Padding="4">
                <TabView x:Name="MainTabView" IsAddTabButtonVisible="False" TabWidthMode="Equal" RequestedTheme="Dark" SelectionChanged="OnMainTabViewSelectionChanged">
                <TabViewItem Header="SoundBoard" IsClosable="False">
                    <Grid x:Name="SoundBoardTabRoot" Background="Transparent" Padding="0,16,0,0" RowSpacing="4" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" AllowDrop="True" DragOver="OnSoundBoardDragOver" DragLeave="OnSoundBoardDragLeave" Drop="OnSoundBoardDrop">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <!-- HEAD -->
                        <Border Grid.Row="0" Padding="6">
                            <Grid ColumnSpacing="8" MinHeight="124">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="360" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="104" />
                                </Grid.RowDefinitions>

                                <Border Grid.Column="0" Grid.Row="1" Padding="0" Width="164" Height="104" HorizontalAlignment="Left" VerticalAlignment="Top">
                                    <Grid RowSpacing="8" ColumnSpacing="8">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="48" />
                                            <RowDefinition Height="48" />
                                        </Grid.RowDefinitions>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="78" />
                                            <ColumnDefinition Width="78" />
                                        </Grid.ColumnDefinitions>
                                        <Button Style="{ThemeResource VoiSee.Style.Button.SoundBoardTransport}" Grid.Row="0" Grid.Column="0" x:Name="PreviousSoundButton" Content="&#xE892;" FontFamily="Segoe MDL2 Assets" FontSize="18" MinWidth="0" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Click="OnPreviousSoundClick" ToolTipService.ToolTip="Previous track" />
                                        <Button Style="{ThemeResource VoiSee.Style.Button.SoundBoardTransport}" Grid.Row="0" Grid.Column="1" x:Name="NextSoundButton" Content="&#xE893;" FontFamily="Segoe MDL2 Assets" FontSize="18" MinWidth="0" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Click="OnNextSoundClick" ToolTipService.ToolTip="Next track" />
                                        <ToggleButton Style="{ThemeResource VoiSee.Style.ToggleButton}" Grid.Row="1" Grid.Column="0" x:Name="SoundLoopToggleButton" Content="∞" FontSize="20" MinWidth="0" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Checked="OnSoundLoopToggleChanged" Unchecked="OnSoundLoopToggleChanged" ToolTipService.ToolTip="Loop current SoundBoard track" />
                                        <Button Style="{ThemeResource VoiSee.Style.Button.SoundBoardTransport}" Grid.Row="1" Grid.Column="1" x:Name="StopSoundButton" Content="Stop" MinWidth="0" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Click="OnStopSoundClick" ToolTipService.ToolTip="Stop sound" />
                                    </Grid>
                                </Border>

                                <Border Grid.Row="0" Grid.Column="1" Grid.ColumnSpan="2" Padding="2">
                                    <TextBlock Style="{ThemeResource VoiSee.Style.Text.Secondary}" x:Name="TransportStatusTextBlock" Text="No sound" HorizontalAlignment="Center" Opacity="0.75" />
                                </Border>

                                <Border Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="2" Padding="0" Height="104" VerticalAlignment="Top">
                                    <Grid Height="104" ColumnSpacing="8" RowSpacing="8" VerticalAlignment="Top">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="56" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="76" />
                                            <RowDefinition Height="20" />
                                        </Grid.RowDefinitions>

                                        <Button Style="{ThemeResource VoiSee.Style.Button.SoundBoardTransport}" Grid.Row="0" Grid.Column="0" x:Name="PlayPauseButton" Content="&#xE768;" FontFamily="Segoe MDL2 Assets" FontSize="22" MinWidth="0" Width="56" Height="48" HorizontalAlignment="Left" VerticalAlignment="Center" Click="OnPlayPauseSoundClick" ToolTipService.ToolTip="Play / Pause">
                                            <Button.RenderTransform>
                                                <TranslateTransform Y="10" />
                                            </Button.RenderTransform>
                                        </Button>

                                        <Grid Grid.Row="0" Grid.Column="1" x:Name="TimelineHost" Height="48" VerticalAlignment="Center" Background="{ThemeResource VoiSee.TimelineHostBrush}" PointerPressed="OnTimelineHostPointerPressed" PointerMoved="OnTimelineHostPointerMoved" PointerReleased="OnTimelineHostPointerReleased" PointerCanceled="OnTimelineHostPointerReleased" SizeChanged="OnTimelineHostSizeChanged">
                                            <Grid.RenderTransform>
                                                <TranslateTransform Y="10" />
                                            </Grid.RenderTransform>
                                            <Grid Height="8" VerticalAlignment="Center">
                                                <Border Background="{ThemeResource VoiSee.TimelineTrackBrush}" CornerRadius="{ThemeResource VoiSee.CornerRadius.Small}" />
                                                <Border x:Name="TimelineFill" Width="0" HorizontalAlignment="Left" Background="{ThemeResource VoiSee.TimelineFillBrush}" CornerRadius="{ThemeResource VoiSee.CornerRadius.Small}" />
                                            </Grid>
                                            <Ellipse x:Name="TimelineThumb" Width="16" Height="16" HorizontalAlignment="Left" VerticalAlignment="Center" Fill="{ThemeResource VoiSee.TimelineThumbBrush}">
                                                <Ellipse.RenderTransform>
                                                    <TranslateTransform x:Name="TimelineThumbTransform" X="0" />
                                                </Ellipse.RenderTransform>
                                            </Ellipse>
                                        </Grid>

                                        <Grid Grid.Row="1" Grid.Column="1" VerticalAlignment="Bottom">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock x:Name="CurrentTimeTextBlock" Text="00:00" VerticalAlignment="Bottom" />
                                            <TextBlock Grid.Column="2" x:Name="TotalTimeTextBlock" Text="00:00" VerticalAlignment="Bottom" />
                                        </Grid>
                                    </Grid>
                                </Border>

                                <Border Grid.Row="0" Grid.RowSpan="2" Grid.Column="3" Padding="6">
                                    <StackPanel Spacing="6" VerticalAlignment="Top">
                                        <TextBlock x:Name="SoundVirtualVolumeLabel" Text="SoundBoard → Virtual Mic: 100%" FontWeight="SemiBold" />
                                        <Slider Style="{ThemeResource VoiSee.Style.Slider}" x:Name="SoundVirtualVolumeSlider" Minimum="0" Maximum="1.5" Value="1" StepFrequency="0.01" ValueChanged="OnSoundVolumeChanged" />
                                        <TextBlock x:Name="SoundMonitorVolumeLabel" Text="SoundBoard → Headphones: 100%" FontWeight="SemiBold" />
                                        <Slider Style="{ThemeResource VoiSee.Style.Slider}" x:Name="SoundMonitorVolumeSlider" Minimum="0" Maximum="1.5" Value="1" StepFrequency="0.01" ValueChanged="OnSoundVolumeChanged" />
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </Border>

                        <!-- BODY -->
                        <Border Grid.Row="1" Padding="6">
                            <Grid x:Name="SoundBoardBodyGrid" ColumnSpacing="0" Background="Transparent" VerticalAlignment="Stretch">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="20*" />
                                    <ColumnDefinition Width="2*" />
                                    <ColumnDefinition Width="78*" />
                                </Grid.ColumnDefinitions>

                                <!-- LEFT: categories and category info panel -->
                                <Grid Grid.Column="0" RowSpacing="8" VerticalAlignment="Stretch">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="*" />
                                    </Grid.RowDefinitions>

                                    <Grid Grid.Row="0" ColumnSpacing="8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Button Style="{ThemeResource VoiSee.Style.Button}" Grid.Column="0" Content="Create" HorizontalAlignment="Stretch" Click="OnAddCategoryClick" />
                                        <Button Style="{ThemeResource VoiSee.Style.Button}" Grid.Column="1" Content="Rename" HorizontalAlignment="Stretch" Click="OnRenameCategoryClick" />
                                        <Button Style="{ThemeResource VoiSee.Style.Button}" Grid.Column="2" Content="Delete" HorizontalAlignment="Stretch" Click="OnDeleteCategoryClick" />
                                    </Grid>
                                    <ComboBox Style="{ThemeResource VoiSee.Style.ComboBox}" Grid.Row="1"
                                              x:Name="CategoryComboBox"
                                              PlaceholderText="Choose category"
                                              DisplayMemberPath="Name"
                                              SelectionChanged="OnCategorySelectionChanged"
                                              HorizontalAlignment="Stretch" />

                                    <Border Grid.Row="2" Margin="0,12,0,0" Padding="10" Background="{ThemeResource VoiSee.PanelBackgroundBrush}" BorderBrush="{ThemeResource VoiSee.PanelBorderBrush}" BorderThickness="1" HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
                                        <TextBlock Style="{ThemeResource VoiSee.Style.Text.Secondary}" x:Name="CategoryInfoTextBlock"
                                                   Text="Categories: 0&#x0a;Tracks in category: 0&#x0a;Category uses: 0"
                                                   TextWrapping="Wrap"
                                                   Opacity="0.82" />
                                    </Border>
                                </Grid>

                                <!-- RIGHT: header, search/actions, then scrollable sound list -->
                                <Grid Grid.Column="2" RowSpacing="8" VerticalAlignment="Stretch" HorizontalAlignment="Stretch">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="*" />
                                    </Grid.RowDefinitions>

                                    <TextBlock Grid.Row="0" Text="Sounds" FontSize="18" FontWeight="SemiBold" />

                                    <Grid Grid.Row="1" ColumnSpacing="12" HorizontalAlignment="Stretch">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>

                                        <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8" HorizontalAlignment="Left">
                                            <TextBox Style="{ThemeResource VoiSee.Style.TextBox}" x:Name="TrackSearchTextBox"
                                                     Width="360"
                                                     PlaceholderText="Search track"
                                                     KeyDown="OnTrackSearchKeyDown" />
                                            <Button Style="{ThemeResource VoiSee.Style.Button}" Content="Find" Click="OnSearchTrackClick" />
                                        </StackPanel>

                                        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right">
                                            <Button Style="{ThemeResource VoiSee.Style.Button}" Content="Add Track" Click="OnAddSoundClick" />
                                            <Button Style="{ThemeResource VoiSee.Style.Button}" Content="Delete Track" Click="OnDeleteSoundClick" />
                                        </StackPanel>
                                    </Grid>

                                    <Border Grid.Row="2"
                                            x:Name="SoundListArea"
                                            Background="Transparent"
                                            Padding="0"
                                            VerticalAlignment="Stretch"
                                            HorizontalAlignment="Stretch">
                                        <Grid Background="Transparent">
                                            <!-- Gate 5.29: visual scroller; input is handled by SoundInputOverlay above it. -->
                                            <ScrollViewer x:Name="SoundOverlayScrollViewer"
                                                          VerticalScrollBarVisibility="Auto"
                                                          VerticalScrollMode="Enabled"
                                                          HorizontalScrollBarVisibility="Disabled"
                                                          HorizontalScrollMode="Disabled"
                                                          ZoomMode="Disabled"
                                                          HorizontalAlignment="Stretch"
                                                          VerticalAlignment="Stretch">
                                                <StackPanel x:Name="SoundItemsPanel" Spacing="4" Padding="0,0,48,8" />
                                            </ScrollViewer>

                                            <!-- Gate 5.34: local input overlay lives in the same cell as the visual Sounds list.
                                                 No TransformToVisual/Margin positioning, so the wheel/click zone cannot drift in fullscreen. -->
                                            <Border x:Name="SoundInputOverlay"
                                                    Background="{ThemeResource VoiSee.TransparentHitTestBrush}"
                                                    AllowDrop="True"
                                                    DragOver="OnSoundBoardDragOver"
                                                    DragLeave="OnSoundBoardDragLeave"
                                                    Drop="OnSoundBoardDrop"
                                                    HorizontalAlignment="Stretch"
                                                    VerticalAlignment="Stretch"
                                                    Canvas.ZIndex="1000"
                                                    PointerPressed="OnSoundInputOverlayPointerPressed" />
                                        </Grid>
                                    </Border>
                                </Grid>
                            </Grid>
                        </Border>

                        <Border Grid.Row="0" Grid.RowSpan="2"
                                x:Name="SoundBoardSceneLockOverlay"
                                Visibility="Collapsed"
                                IsHitTestVisible="False"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Padding="18,12"
                                CornerRadius="{ThemeResource VoiSee.CornerRadius.Medium}"
                                Background="{ThemeResource VoiSee.DropOverlayInnerBackgroundBrush}"
                                BorderBrush="{ThemeResource VoiSee.DropOverlayInnerBorderBrush}"
                                BorderThickness="1">
                            <TextBlock Text="SoundBoard playback is unavailable while a scene is active"
                                       FontWeight="SemiBold"
                                       TextAlignment="Center" />
                        </Border>
                    </Grid>
                </TabViewItem>

                <TabViewItem Header="Voice Changer" IsClosable="False">
                    <ScrollViewer x:Name="VoiceChangerScrollViewer" Background="Transparent" VerticalScrollBarVisibility="Auto" VerticalScrollMode="Enabled" HorizontalScrollBarVisibility="Disabled" HorizontalScrollMode="Disabled" ZoomMode="Disabled">
                        <StackPanel Spacing="22" Padding="0,16,48,24">
                            <Grid ColumnSpacing="16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Spacing="4">
                                    <TextBlock Text="Voice processing" FontSize="20" FontWeight="SemiBold" />
                                    <TextBlock Text="Connected DSP sliders are shown. Pitch is a real-time low-latency shifter; sliders use -100..+100. Number fields allow -9999..+9999 for experimental presets." Opacity="0.72" TextWrapping="Wrap" />
                                    <TextBlock Text="Warning: extreme values can cause loud audio, clipping, instability, or device/output problems. Increase them carefully." Opacity="0.82" Foreground="{ThemeResource VoiSee.WarningBrush}" TextWrapping="Wrap" />
                                </StackPanel>
                                <Button Style="{ThemeResource VoiSee.Style.Button}" Grid.Column="1"
                                        x:Name="VoiceMonitorButton"
                                        Content="Voice Monitor: Off"
                                        MinWidth="180"
                                        Height="44"
                                        HorizontalAlignment="Right"
                                        VerticalAlignment="Top"
                                        Click="OnToggleVoiceMonitorClick" />
                            </Grid>

                                                        <Grid ColumnSpacing="18" RowSpacing="18">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <StackPanel Grid.Row="0" Grid.Column="0" Spacing="6">
                                    <Grid ColumnSpacing="8">
                                        <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="70" /></Grid.ColumnDefinitions>
                                        <TextBlock x:Name="VoiceGainLabel" Text="Voice Gain" FontWeight="SemiBold" VerticalAlignment="Center" />
                                        <TextBox Style="{ThemeResource VoiSee.Style.TextBox}" Grid.Column="1" x:Name="VoiceGainValueBox" Text="0" MaxLength="5" TextAlignment="Right" TextChanged="OnVoiceValueTextChanged" />
                                    </Grid>
                                    <Slider Style="{ThemeResource VoiSee.Style.Slider}" x:Name="VoiceGainSlider" Minimum="-100" Maximum="100" Value="0" StepFrequency="1" ValueChanged="OnVoiceSettingsChanged" />
                                </StackPanel>

                                <StackPanel Grid.Row="0" Grid.Column="1" Spacing="6">
                                    <Grid ColumnSpacing="8">
                                        <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="70" /></Grid.ColumnDefinitions>
                                        <TextBlock x:Name="GateThresholdLabel" Text="Gate" FontWeight="SemiBold" VerticalAlignment="Center" />
                                        <TextBox Style="{ThemeResource VoiSee.Style.TextBox}" Grid.Column="1" x:Name="GateThresholdValueBox" Text="0" MaxLength="5" TextAlignment="Right" TextChanged="OnVoiceValueTextChanged" />
                                    </Grid>
                                    <Slider Style="{ThemeResource VoiSee.Style.Slider}" x:Name="GateThresholdSlider" Minimum="-100" Maximum="100" Value="0" StepFrequency="1" ValueChanged="OnVoiceSettingsChanged" />
                                </StackPanel>

                                <StackPanel Grid.Row="0" Grid.Column="2" Spacing="6">
                                    <Grid ColumnSpacing="8">
                                        <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="70" /></Grid.ColumnDefinitions>
                                        <TextBlock x:Name="CompressorThresholdLabel" Text="Compressor" FontWeight="SemiBold" VerticalAlignment="Center" />
                                        <TextBox Style="{ThemeResource VoiSee.Style.TextBox}" Grid.Column="1" x:Name="CompressorThresholdValueBox" Text="0" MaxLength="5" TextAlignment="Right" TextChanged="OnVoiceValueTextChanged" />
                                    </Grid>
                                    <Slider Style="{ThemeResource VoiSee.Style.Slider}" x:Name="CompressorThresholdSlider" Minimum="-100" Maximum="100" Value="0" StepFrequency="1" ValueChanged="OnVoiceSettingsChanged" />
                                </StackPanel>

                                <StackPanel Grid.Row="0" Grid.Column="3" Spacing="6">
                                    <Grid ColumnSpacing="8">
                                        <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="70" /></Grid.ColumnDefinitions>
                                        <TextBlock x:Name="PitchLabel" Text="Pitch" FontWeight="SemiBold" VerticalAlignment="Center" />
                                        <TextBox Style="{ThemeResource VoiSee.Style.TextBox}" Grid.Column="1" x:Name="PitchValueBox" Text="0" MaxLength="5" TextAlignment="Right" TextChanged="OnVoiceValueTextChanged" />
                                    </Grid>
                                    <Slider Style="{ThemeResource VoiSee.Style.Slider}" x:Name="PitchSlider" Minimum="-100" Maximum="100" Value="0" StepFrequency="1" ValueChanged="OnVoiceSettingsChanged" />
                                </StackPanel>

                                <StackPanel Grid.Row="1" Grid.Column="0" Spacing="6">
                                    <Grid ColumnSpacing="8">
                                        <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="70" /></Grid.ColumnDefinitions>
                                        <TextBlock x:Name="FormantLabel" Text="Formant" FontWeight="SemiBold" VerticalAlignment="Center" />
                                        <TextBox Style="{ThemeResource VoiSee.Style.TextBox}" Grid.Column="1" x:Name="FormantValueBox" Text="0" MaxLength="5" TextAlignment="Right" TextChanged="OnVoiceValueTextChanged" />
                                    </Grid>
                                    <Slider Style="{ThemeResource VoiSee.Style.Slider}" x:Name="FormantSlider" Minimum="-100" Maximum="100" Value="0" StepFrequency="1" ValueChanged="OnVoiceSettingsChanged" />
                                </StackPanel>

                                <StackPanel Grid.Row="1" Grid.Column="1" Spacing="6">
                                    <Grid ColumnSpacing="8">
                                        <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="70" /></Grid.ColumnDefinitions>
                                        <TextBlock x:Name="BassLabel" Text="Bass" FontWeight="SemiBold" VerticalAlignment="Center" />
                                        <TextBox Style="{ThemeResource VoiSee.Style.TextBox}" Grid.Column="1" x:Name="BassValueBox" Text="0" MaxLength="5" TextAlignment="Right" TextChanged="OnVoiceValueTextChanged" />
                                    </Grid>
                                    <Slider Style="{ThemeResource VoiSee.Style.Slider}" x:Name="BassSlider" Minimum="-100" Maximum="100" Value="0" StepFrequency="1" ValueChanged="OnVoiceSettingsChanged" />
                                </StackPanel>

                                <StackPanel Grid.Row="1" Grid.Column="2" Spacing="6">
                                    <Grid ColumnSpacing="8">
                                        <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="70" /></Grid.ColumnDefinitions>
                                        <TextBlock x:Name="TrebleLabel" Text="Treble" FontWeight="SemiBold" VerticalAlignment="Center" />
                                        <TextBox Style="{ThemeResource VoiSee.Style.TextBox}" Grid.Column="1" x:Name="TrebleValueBox" Text="0" MaxLength="5" TextAlignment="Right" TextChanged="OnVoiceValueTextChanged" />
                                    </Grid>
                                    <Slider Style="{ThemeResource VoiSee.Style.Slider}" x:Name="TrebleSlider" Minimum="-100" Maximum="100" Value="0" StepFrequency="1" ValueChanged="OnVoiceSettingsChanged" />
                                </StackPanel>

                                <StackPanel Grid.Row="1" Grid.Column="3" Spacing="6">
                                    <Grid ColumnSpacing="8">
                                        <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="70" /></Grid.ColumnDefinitions>
                                        <TextBlock x:Name="DistortionLabel" Text="Distortion" FontWeight="SemiBold" VerticalAlignment="Center" />
                                        <TextBox Style="{ThemeResource VoiSee.Style.TextBox}" Grid.Column="1" x:Name="DistortionValueBox" Text="0" MaxLength="5" TextAlignment="Right" TextChanged="OnVoiceValueTextChanged" />
                                    </Grid>
                                    <Slider Style="{ThemeResource VoiSee.Style.Slider}" x:Name="DistortionSlider" Minimum="-100" Maximum="100" Value="0" StepFrequency="1" ValueChanged="OnVoiceSettingsChanged" />
                                </StackPanel>

                                <StackPanel Grid.Row="2" Grid.Column="0" Spacing="6">
                                    <Grid ColumnSpacing="8">
                                        <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="70" /></Grid.ColumnDefinitions>
                                        <TextBlock x:Name="RobotLabel" Text="Robot" FontWeight="SemiBold" VerticalAlignment="Center" />
                                        <TextBox Style="{ThemeResource VoiSee.Style.TextBox}" Grid.Column="1" x:Name="RobotValueBox" Text="0" MaxLength="5" TextAlignment="Right" TextChanged="OnVoiceValueTextChanged" />
                                    </Grid>
                                    <Slider Style="{ThemeResource VoiSee.Style.Slider}" x:Name="RobotSlider" Minimum="-100" Maximum="100" Value="0" StepFrequency="1" ValueChanged="OnVoiceSettingsChanged" />
                                </StackPanel>

                                <StackPanel Grid.Row="2" Grid.Column="1" Spacing="6">
                                    <Grid ColumnSpacing="8">
                                        <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="70" /></Grid.ColumnDefinitions>
                                        <TextBlock x:Name="TremoloLabel" Text="Tremolo" FontWeight="SemiBold" VerticalAlignment="Center" />
                                        <TextBox Style="{ThemeResource VoiSee.Style.TextBox}" Grid.Column="1" x:Name="TremoloValueBox" Text="0" MaxLength="5" TextAlignment="Right" TextChanged="OnVoiceValueTextChanged" />
                                    </Grid>
                                    <Slider Style="{ThemeResource VoiSee.Style.Slider}" x:Name="TremoloSlider" Minimum="-100" Maximum="100" Value="0" StepFrequency="1" ValueChanged="OnVoiceSettingsChanged" />
                                </StackPanel>

                                <StackPanel Grid.Row="2" Grid.Column="2" Spacing="6">
                                    <Grid ColumnSpacing="8">
                                        <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="70" /></Grid.ColumnDefinitions>
                                        <TextBlock x:Name="EchoLabel" Text="Echo" FontWeight="SemiBold" VerticalAlignment="Center" />
                                        <TextBox Style="{ThemeResource VoiSee.Style.TextBox}" Grid.Column="1" x:Name="EchoValueBox" Text="0" MaxLength="5" TextAlignment="Right" TextChanged="OnVoiceValueTextChanged" />
                                    </Grid>
                                    <Slider Style="{ThemeResource VoiSee.Style.Slider}" x:Name="EchoSlider" Minimum="-100" Maximum="100" Value="0" StepFrequency="1" ValueChanged="OnVoiceSettingsChanged" />
                                </StackPanel>

                                <StackPanel Grid.Row="2" Grid.Column="3" Spacing="6">
                                    <Grid ColumnSpacing="8">
                                        <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="70" /></Grid.ColumnDefinitions>
