<Window
    x:Class="VoiSe.App.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="VoiSe Gate 5 - SoundBoard Library">

    <Grid Padding="20" RowSpacing="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Spacing="4">
            <TextBlock Text="VoiSe Gate 5" FontSize="28" FontWeight="SemiBold" />
            <TextBlock Text="SoundBoard Library: categories, copied sound files, metadata persistence, and unified mixer playback" Opacity="0.75" />
        </StackPanel>

        <TabView Grid.Row="1" IsAddTabButtonVisible="False" TabWidthMode="Equal">
            <TabViewItem Header="SoundBoard" IsClosable="False">
                <Grid Padding="0,16,0,0" ColumnSpacing="18" RowSpacing="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="280" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Grid.Column="0" Spacing="8">
                        <TextBlock Text="Categories" FontSize="18" FontWeight="SemiBold" />
                        <ComboBox x:Name="CategoryComboBox" DisplayMemberPath="Name" PlaceholderText="Choose category" SelectionChanged="OnCategorySelectionChanged" Width="260" />
                        <Grid ColumnSpacing="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="NewCategoryTextBox" PlaceholderText="New category" />
                            <Button Grid.Column="1" Content="Add" Click="OnAddCategoryClick" />
                        </Grid>
                    </StackPanel>

                    <StackPanel Grid.Row="0" Grid.Column="1" Spacing="8">
                        <TextBlock Text="Sounds" FontSize="18" FontWeight="SemiBold" />
                        <Grid ColumnSpacing="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="SoundSearchTextBox" PlaceholderText="Search sounds" TextChanged="OnSoundSearchChanged" />
                            <Button Grid.Column="1" Content="Add Sound" Click="OnAddSoundClick" />
                            <Button Grid.Column="2" Content="Delete" Click="OnDeleteSoundClick" />
                        </Grid>
                    </StackPanel>

                    <ListView Grid.Row="1" Grid.Column="0" x:Name="CategoryListView" DisplayMemberPath="Name" SelectionChanged="OnCategoryListSelectionChanged" />
                    <ListView Grid.Row="1" Grid.Column="1" x:Name="SoundListView" DisplayMemberPath="DisplayName" SelectionChanged="OnSoundSelectionChanged" />

                    <StackPanel Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2" Spacing="10">
                        <TextBlock x:Name="SelectedSoundLabel" Text="Selected sound: none" FontWeight="SemiBold" />
                        <Grid ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <Button Content="Play Selected" Click="OnPlaySoundClick" />
                            <Button Grid.Column="1" Content="Stop Sound" Click="OnStopSoundClick" />
                        </Grid>

                        <TextBlock Text="SoundBoard routing" FontSize="18" FontWeight="SemiBold" />
                        <StackPanel Spacing="8">
                            <TextBlock x:Name="DelayLabel" Text="SoundBoard Virtual Mic Delay: 85 ms" FontWeight="SemiBold" />
                            <Slider x:Name="SoundVirtualDelaySlider" Minimum="0" Maximum="300" Value="85" StepFrequency="1" ValueChanged="OnDelayChanged" />
                            <TextBlock Text="SoundBoard plays in headphones immediately, then reaches CABLE Input after this delay. Changes apply on next Play Sound." Opacity="0.7" TextWrapping="Wrap" />
                        </StackPanel>

                        <Grid ColumnSpacing="20">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Spacing="8">
                                <TextBlock x:Name="SoundVirtualVolumeLabel" Text="SoundBoard → Virtual Mic: 100%" FontWeight="SemiBold" />
                                <Slider x:Name="SoundVirtualVolumeSlider" Minimum="0" Maximum="1.5" Value="1" StepFrequency="0.01" ValueChanged="OnSoundVolumeChanged" />
                            </StackPanel>
                            <StackPanel Grid.Column="1" Spacing="8">
                                <TextBlock x:Name="SoundMonitorVolumeLabel" Text="SoundBoard → Headphones: 100%" FontWeight="SemiBold" />
                                <Slider x:Name="SoundMonitorVolumeSlider" Minimum="0" Maximum="1.5" Value="1" StepFrequency="0.01" ValueChanged="OnSoundVolumeChanged" />
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Grid>
            </TabViewItem>

            <TabViewItem Header="Voice Changer" IsClosable="False">
                <ScrollViewer>
                    <StackPanel Spacing="16" Padding="0,16,0,0">
                        <InfoBar IsOpen="True" Severity="Informational" Title="Live voice settings" Message="Voice sliders are applied to the running engine without manual restart." />
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <Button x:Name="VoiceMonitorButton" Content="Voice Monitor: Off" Click="OnToggleVoiceMonitorClick" />
                            <TextBlock Text="When enabled, your processed voice is sent to headphones at 100%. SoundBoard monitoring is controlled separately in SoundBoard." VerticalAlignment="Center" Opacity="0.75" TextWrapping="Wrap" />
                        </StackPanel>
                        <StackPanel Spacing="8">
                            <TextBlock x:Name="VoiceGainLabel" Text="Voice Gain: 0 dB" FontWeight="SemiBold" />
                            <Slider x:Name="VoiceGainSlider" Minimum="-24" Maximum="12" Value="0" StepFrequency="1" ValueChanged="OnVoiceSettingsChanged" />
                        </StackPanel>
                        <StackPanel Spacing="8">
                            <TextBlock x:Name="GateThresholdLabel" Text="Gate Threshold: -45 dB" FontWeight="SemiBold" />
                            <Slider x:Name="GateThresholdSlider" Minimum="-70" Maximum="-20" Value="-45" StepFrequency="1" ValueChanged="OnVoiceSettingsChanged" />
                        </StackPanel>
                        <StackPanel Spacing="8">
                            <TextBlock x:Name="CompressorThresholdLabel" Text="Compressor Threshold: -18 dB" FontWeight="SemiBold" />
                            <Slider x:Name="CompressorThresholdSlider" Minimum="-40" Maximum="0" Value="-18" StepFrequency="1" ValueChanged="OnVoiceSettingsChanged" />
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </TabViewItem>

            <TabViewItem Header="Scenes" IsClosable="False">
                <StackPanel Spacing="12" Padding="0,16,0,0">
                    <InfoBar IsOpen="True" Severity="Informational" Title="Coming next" Message="Scenes are not implemented in Gate 5. This tab reserves the final navigation structure from the start." />
                    <TextBlock Text="Planned scene content:" FontSize="18" FontWeight="SemiBold" />
                    <TextBlock Text="• voice preset&#x0a;• one background loop sound&#x0a;• several one-shot sounds&#x0a;• scene mixer settings" />
                </StackPanel>
            </TabViewItem>

            <TabViewItem Header="Settings" IsClosable="False">
                <ScrollViewer>
                    <StackPanel Spacing="18" Padding="0,16,0,0">
                        <TextBlock Text="Audio devices" FontSize="18" FontWeight="SemiBold" />
                        <Button Content="Refresh Devices" Click="OnRefreshDevicesClick" HorizontalAlignment="Left" />

                        <StackPanel Spacing="6">
                            <TextBlock Text="Input Microphone" />
                            <ComboBox x:Name="InputDeviceComboBox" PlaceholderText="Choose microphone" DisplayMemberPath="FriendlyName" Width="640" SelectionChanged="OnRouteSettingChanged" />
                        </StackPanel>
                        <StackPanel Spacing="6">
                            <TextBlock Text="Virtual Output" />
                            <ComboBox x:Name="VirtualOutputComboBox" PlaceholderText="Choose CABLE Input" DisplayMemberPath="FriendlyName" Width="640" SelectionChanged="OnRouteSettingChanged" />
                        </StackPanel>
                        <StackPanel Spacing="6">
                            <TextBlock Text="Monitor Output" />
                            <ComboBox x:Name="MonitorOutputComboBox" PlaceholderText="Choose headphones" DisplayMemberPath="FriendlyName" Width="640" SelectionChanged="OnRouteSettingChanged" />
                        </StackPanel>

                        <Grid ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <Button Content="Start Engine" Click="OnStartEngineClick" />
                            <Button Grid.Column="1" Content="Stop Engine" Click="OnStopEngineClick" />
                        </Grid>

                        <TextBlock Text="Output volume" FontSize="18" FontWeight="SemiBold" />
                        <StackPanel Spacing="8">
                            <TextBlock x:Name="VirtualOutputVolumeLabel" Text="Virtual Mic Master: 100%" FontWeight="SemiBold" />
                            <Slider x:Name="VirtualOutputVolumeSlider" Minimum="0" Maximum="1.5" Value="1" StepFrequency="0.01" ValueChanged="OnOutputVolumeChanged" />
                            <TextBlock Text="Global volume of everything sent to the virtual microphone: processed voice + SoundBoard." Opacity="0.7" TextWrapping="Wrap" />
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </TabViewItem>
        </TabView>

        <Grid Grid.Row="2" ColumnSpacing="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" Padding="12" CornerRadius="8">
                <StackPanel>
                    <TextBlock Text="Engine status" FontWeight="SemiBold" />
                    <TextBlock x:Name="EngineStatusTextBlock" Text="Stopped" />
                </StackPanel>
            </Border>
            <TextBox Grid.Column="1" x:Name="LogTextBox" Header="Log" IsReadOnly="True" AcceptsReturn="True" TextWrapping="Wrap" Height="96" />
        </Grid>
    </Grid>
</Window>
