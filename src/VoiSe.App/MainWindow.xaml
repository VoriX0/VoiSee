<Window
    x:Class="VoiSe.App.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:VoiSe.App"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="VoiSee Version 9.2.3">

    <Grid x:Name="RootGrid" RequestedTheme="Dark" Background="#000000">
        <Grid.RowDefinitions>
            <RowDefinition Height="32" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid x:Name="CustomTitleBar" Grid.Row="0" Background="#000000" Height="32" VerticalAlignment="Top">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="138" />
            </Grid.ColumnDefinitions>
            <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center" Margin="10,0,0,0">
                <Image Source="ms-appx:///Assets/AppIcon_24.png" Width="16" Height="16" VerticalAlignment="Center" />
                <TextBlock x:Name="TitleBarVersionTextBlock" Text="VoiSee Version 9.2.3" FontSize="12" Foreground="White" VerticalAlignment="Center" />
            </StackPanel>
        </Grid>

        <Grid Grid.Row="1" Padding="20" RowSpacing="14">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

        <Border x:Name="MainHeaderBorder" Grid.Row="0" Padding="6" MinHeight="46">
            <Grid ColumnSpacing="16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                    <Image Source="ms-appx:///Assets/AppIcon_48.png" Width="34" Height="34" VerticalAlignment="Center" />
                    <TextBlock x:Name="MainTitle" Text="VoiSee Version 9.2.3" FontSize="28" FontWeight="SemiBold" Foreground="White" VerticalAlignment="Center" />
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="10" VerticalAlignment="Center" HorizontalAlignment="Right">
                    <TextBlock Text="Mic Output" Foreground="White" Opacity="0.62" VerticalAlignment="Center" />
                    <TextBlock x:Name="VirtualMicMuteStatusTextBlock" Text="Live" Foreground="#FF37D67A" Opacity="0.95" FontWeight="SemiBold" VerticalAlignment="Center" />
                    <Button x:Name="VirtualMicMuteToggleButton" Content="Mute" MinWidth="92" Padding="10,4" Click="OnVirtualMicMuteToggleClick" />
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1" x:Name="MainContentHost" RowSpacing="8">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <Border x:Name="VirtualMicMutedBanner" Grid.Row="0" Background="#44220000" BorderBrush="#88FF4D4D" BorderThickness="1" CornerRadius="10" Padding="12,8" Visibility="Collapsed">
                <TextBlock Text="Virtual mic output is muted. You can still hear VoiSee in headphones, but Discord/OBS/games receive silence." Foreground="White" FontWeight="SemiBold" TextWrapping="WrapWholeWords" />
            </Border>
            <Border x:Name="MainTabHostBorder" Grid.Row="1" Padding="4">
                <TabView x:Name="MainTabView" IsAddTabButtonVisible="False" TabWidthMode="Equal" RequestedTheme="Dark" SelectionChanged="OnMainTabViewSelectionChanged">
                <TabViewItem Header="SoundBoard" IsClosable="False">
                    <Grid x:Name="SoundBoardTabRoot" Background="Transparent" Padding="0,16,0,0" RowSpacing="4" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" AllowDrop="True" DragOver="OnSoundBoardDragOver" DragLeave="OnSoundBoardDragLeave" Drop="OnSoundBoardDrop">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <!-- HEAD -->
                        <Border Grid.Row="0" Padding="6">
                            <Grid ColumnSpacing="8" MinHeight="124">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="360" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="104" />
                                </Grid.RowDefinitions>

                                <Border Grid.Column="0" Grid.Row="1" Padding="0" Width="164" Height="104" HorizontalAlignment="Left" VerticalAlignment="Top">
                                    <Grid RowSpacing="8" ColumnSpacing="8">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="48" />
                                            <RowDefinition Height="48" />
                                        </Grid.RowDefinitions>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="78" />
                                            <ColumnDefinition Width="78" />
                                        </Grid.ColumnDefinitions>
                                        <Button Grid.Row="0" Grid.Column="0" x:Name="PreviousSoundButton" Content="&#xE892;" FontFamily="Segoe MDL2 Assets" FontSize="18" MinWidth="0" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Click="OnPreviousSoundClick" ToolTipService.ToolTip="Previous track" />
                                        <Button Grid.Row="0" Grid.Column="1" x:Name="NextSoundButton" Content="&#xE893;" FontFamily="Segoe MDL2 Assets" FontSize="18" MinWidth="0" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Click="OnNextSoundClick" ToolTipService.ToolTip="Next track" />
                                        <ToggleButton Grid.Row="1" Grid.Column="0" x:Name="SoundLoopToggleButton" Content="∞" FontSize="20" MinWidth="0" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Checked="OnSoundLoopToggleChanged" Unchecked="OnSoundLoopToggleChanged" ToolTipService.ToolTip="Loop current SoundBoard track" />
                                        <Button Grid.Row="1" Grid.Column="1" x:Name="StopSoundButton" Content="Stop" MinWidth="0" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Click="OnStopSoundClick" ToolTipService.ToolTip="Stop sound" />
                                    </Grid>
                                </Border>

                                <Border Grid.Row="0" Grid.Column="1" Grid.ColumnSpan="2" Padding="2">
                                    <TextBlock x:Name="TransportStatusTextBlock" Text="No sound" HorizontalAlignment="Center" Opacity="0.75" />
                                </Border>

                                <Border Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="2" Padding="0" Height="104" VerticalAlignment="Top">
                                    <Grid Height="104" ColumnSpacing="8" RowSpacing="8" VerticalAlignment="Top">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="56" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="76" />
                                            <RowDefinition Height="20" />
                                        </Grid.RowDefinitions>

                                        <Button Grid.Row="0" Grid.Column="0" x:Name="PlayPauseButton" Content="&#xE768;" FontFamily="Segoe MDL2 Assets" FontSize="22" MinWidth="0" Width="56" Height="48" HorizontalAlignment="Left" VerticalAlignment="Center" Click="OnPlayPauseSoundClick" ToolTipService.ToolTip="Play / Pause">
                                            <Button.RenderTransform>
                                                <TranslateTransform Y="10" />
                                            </Button.RenderTransform>
                                        </Button>

                                        <Grid Grid.Row="0" Grid.Column="1" x:Name="TimelineHost" Height="48" VerticalAlignment="Center" Background="#01000000" PointerPressed="OnTimelineHostPointerPressed" PointerMoved="OnTimelineHostPointerMoved" PointerReleased="OnTimelineHostPointerReleased" PointerCanceled="OnTimelineHostPointerReleased" SizeChanged="OnTimelineHostSizeChanged">
                                            <Grid.RenderTransform>
                                                <TranslateTransform Y="10" />
                                            </Grid.RenderTransform>
                                            <Grid Height="8" VerticalAlignment="Center">
                                                <Border Background="#33FFFFFF" CornerRadius="4" />
                                                <Border x:Name="TimelineFill" Width="0" HorizontalAlignment="Left" Background="#99FFFFFF" CornerRadius="4" />
                                            </Grid>
                                            <Ellipse x:Name="TimelineThumb" Width="16" Height="16" HorizontalAlignment="Left" VerticalAlignment="Center" Fill="#FFFFFFFF">
                                                <Ellipse.RenderTransform>
                                                    <TranslateTransform x:Name="TimelineThumbTransform" X="0" />
                                                </Ellipse.RenderTransform>
                                            </Ellipse>
                                        </Grid>

                                        <Grid Grid.Row="1" Grid.Column="1" VerticalAlignment="Bottom">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock x:Name="CurrentTimeTextBlock" Text="00:00" VerticalAlignment="Bottom" />
                                            <TextBlock Grid.Column="2" x:Name="TotalTimeTextBlock" Text="00:00" VerticalAlignment="Bottom" />
                                        </Grid>
                                    </Grid>
                                </Border>

                                <Border Grid.Row="0" Grid.RowSpan="2" Grid.Column="3" Padding="6">
                                    <StackPanel Spacing="6" VerticalAlignment="Top">
                                        <TextBlock x:Name="SoundVirtualVolumeLabel" Text="SoundBoard → Virtual Mic: 100%" FontWeight="SemiBold" />
                                        <Slider x:Name="SoundVirtualVolumeSlider" Minimum="0" Maximum="1.5" Value="1" StepFrequency="0.01" ValueChanged="OnSoundVolumeChanged" />
                                        <TextBlock x:Name="SoundMonitorVolumeLabel" Text="SoundBoard → Headphones: 100%" FontWeight="SemiBold" />
                                        <Slider x:Name="SoundMonitorVolumeSlider" Minimum="0" Maximum="1.5" Value="1" StepFrequency="0.01" ValueChanged="OnSoundVolumeChanged" />
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </Border>

                        <!-- BODY -->
                        <Border Grid.Row="1" Padding="6">
                            <Grid x:Name="SoundBoardBodyGrid" ColumnSpacing="0" Background="Transparent" VerticalAlignment="Stretch">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="20*" />
                                    <ColumnDefinition Width="2*" />
                                    <ColumnDefinition Width="78*" />
                                </Grid.ColumnDefinitions>

                                <!-- LEFT: categories and category info panel -->
                                <Grid Grid.Column="0" RowSpacing="8" VerticalAlignment="Stretch">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="*" />
                                    </Grid.RowDefinitions>

                                    <Grid Grid.Row="0" ColumnSpacing="8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Button Grid.Column="0" Content="Create" HorizontalAlignment="Stretch" Click="OnAddCategoryClick" />
                                        <Button Grid.Column="1" Content="Rename" HorizontalAlignment="Stretch" Click="OnRenameCategoryClick" />
                                        <Button Grid.Column="2" Content="Delete" HorizontalAlignment="Stretch" Click="OnDeleteCategoryClick" />
                                    </Grid>

                                    <ComboBox Grid.Row="1"
                                              x:Name="CategoryComboBox"
                                              DisplayMemberPath="Name"
                                              PlaceholderText="Choose category"
                                              SelectionChanged="OnCategorySelectionChanged"
                                              HorizontalAlignment="Stretch" />

                                    <Border Grid.Row="2" Margin="0,12,0,0" Padding="10" Background="#08000000" BorderBrush="#22FFFFFF" BorderThickness="1" HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
                                        <TextBlock x:Name="CategoryInfoTextBlock"
                                                   Text="Categories: 0&#x0a;Tracks in category: 0&#x0a;Category uses: 0"
                                                   TextWrapping="Wrap"
                                                   Opacity="0.82" />
                                    </Border>
                                </Grid>

                                <!-- RIGHT: header, search/actions, then scrollable sound list -->
                                <Grid Grid.Column="2" RowSpacing="8" VerticalAlignment="Stretch" HorizontalAlignment="Stretch">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="*" />
                                    </Grid.RowDefinitions>

                                    <TextBlock Grid.Row="0" Text="Sounds" FontSize="18" FontWeight="SemiBold" />

                                    <Grid Grid.Row="1" ColumnSpacing="12" HorizontalAlignment="Stretch">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>

                                        <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8" HorizontalAlignment="Left">
                                            <TextBox x:Name="TrackSearchTextBox"
                                                     Width="360"
                                                     PlaceholderText="Search track"
                                                     KeyDown="OnTrackSearchKeyDown" />
                                            <Button Content="Find" Click="OnSearchTrackClick" />
                                        </StackPanel>

                                        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right">
                                            <Button x:Name="EditSoundButton" Content="Edit Track" Click="OnEditSoundClick" />
                                            <Button Content="Add Track" Click="OnAddSoundClick" />
                                            <Button Content="Delete Track" Click="OnDeleteSoundClick" />
                                        </StackPanel>
                                    </Grid>

                                    <Border Grid.Row="2"
                                            x:Name="SoundListArea"
                                            Background="Transparent"
                                            Padding="0"
                                            VerticalAlignment="Stretch"
                                            HorizontalAlignment="Stretch">
                                        <Grid Background="Transparent">
                                            <!-- Gate 5.29: visual scroller; input is handled by SoundInputOverlay above it. -->
                                            <ScrollViewer x:Name="SoundOverlayScrollViewer"
                                                          VerticalScrollBarVisibility="Auto"
                                                          VerticalScrollMode="Enabled"
                                                          HorizontalScrollBarVisibility="Disabled"
                                                          HorizontalScrollMode="Disabled"
                                                          ZoomMode="Disabled"
                                                          HorizontalAlignment="Stretch"
                                                          VerticalAlignment="Stretch">
                                                <StackPanel x:Name="SoundItemsPanel" Spacing="4" Padding="0,0,48,8" />
                                            </ScrollViewer>

                                            <!-- Gate 5.34: local input overlay lives in the same cell as the visual Sounds list.
                                                 No TransformToVisual/Margin positioning, so the wheel/click zone cannot drift in fullscreen. -->
                                            <Border x:Name="SoundInputOverlay"
                                                    Background="#01000000"
                                                    AllowDrop="True"
                                                    DragOver="OnSoundBoardDragOver"
                                                    DragLeave="OnSoundBoardDragLeave"
                                                    Drop="OnSoundBoardDrop"
                                                    HorizontalAlignment="Stretch"
                                                    VerticalAlignment="Stretch"
                                                    Canvas.ZIndex="1000"
                                                    PointerPressed="OnSoundInputOverlayPointerPressed" />
                                        </Grid>
                                    </Border>
                                </Grid>
                            </Grid>
                        </Border>

                        <Border Grid.Row="0" Grid.RowSpan="2"
                                x:Name="SoundBoardDropOverlay"
                                Visibility="Collapsed"
                                IsHitTestVisible="False"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Padding="22,16"
                                CornerRadius="12"
                                Background="#E0202020"
                                BorderBrush="#66FFFFFF"
                                BorderThickness="1">
                            <TextBlock Text="Drag one or more sound files here and release to add them to the current category"
                                       FontWeight="SemiBold"
                                       TextAlignment="Center"
                                       TextWrapping="Wrap"
                                       MaxWidth="520" />
                        </Border>

                        <Border Grid.Row="0" Grid.RowSpan="2"
                                x:Name="SoundBoardSceneLockOverlay"
                                Visibility="Collapsed"
                                IsHitTestVisible="False"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Padding="18,12"
                                CornerRadius="10"
                                Background="#DD202020"
                                BorderBrush="#55FFFFFF"
                                BorderThickness="1">
                            <TextBlock Text="SoundBoard playback is unavailable while a scene is active"
                                       FontWeight="SemiBold"
                                       TextAlignment="Center" />
                        </Border>
                    </Grid>
                </TabViewItem>

                <TabViewItem Header="Voice Changer" IsClosable="False">
                    <ScrollViewer x:Name="VoiceChangerScrollViewer" Background="Transparent" VerticalScrollBarVisibility="Auto" VerticalScrollMode="Enabled" HorizontalScrollBarVisibility="Disabled" HorizontalScrollMode="Disabled" ZoomMode="Disabled">
                        <StackPanel Spacing="22" Padding="0,16,48,24">
                            <Grid ColumnSpacing="16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Spacing="4">
                                    <TextBlock Text="Voice processing" FontSize="20" FontWeight="SemiBold" />
                                    <TextBlock Text="Connected DSP sliders are shown. Pitch is a real-time low-latency shifter; sliders use -100..+100. Number fields allow -9999..+9999 for experimental presets." Opacity="0.72" TextWrapping="Wrap" />
                                    <TextBlock Text="Warning: extreme values can cause loud audio, clipping, instability, or device/output problems. Increase them carefully." Opacity="0.82" Foreground="#FFFFD166" TextWrapping="Wrap" />
                                </StackPanel>
                                <Button Grid.Column="1"
                                        x:Name="VoiceMonitorButton"
                                        Content="Voice Monitor: Off"
                                        MinWidth="180"
                                        Height="44"
                                        HorizontalAlignment="Right"
                                        VerticalAlignment="Top"
                                        Click="OnToggleVoiceMonitorClick" />
                            </Grid>

                                                        <Grid ColumnSpacing="18" RowSpacing="18">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <StackPanel Grid.Row="0" Grid.Column="0" Spacing="6">
                                    <Grid ColumnSpacing="8">
                                        <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="70" /></Grid.ColumnDefinitions>
                                        <TextBlock x:Name="VoiceGainLabel" Text="Voice Gain" FontWeight="SemiBold" VerticalAlignment="Center" />
                                        <TextBox Grid.Column="1" x:Name="VoiceGainValueBox" Text="0" MaxLength="5" TextAlignment="Right" TextChanged="OnVoiceValueTextChanged" />
                                    </Grid>
                                    <Slider x:Name="VoiceGainSlider" Minimum="-100" Maximum="100" Value="0" StepFrequency="1" ValueChanged="OnVoiceSettingsChanged" />
                                </StackPanel>

                                <StackPanel Grid.Row="0" Grid.Column="1" Spacing="6">
                                    <Grid ColumnSpacing="8">
                                        <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="70" /></Grid.ColumnDefinitions>
                                        <TextBlock x:Name="GateThresholdLabel" Text="Gate" FontWeight="SemiBold" VerticalAlignment="Center" />
                                        <TextBox Grid.Column="1" x:Name="GateThresholdValueBox" Text="0" MaxLength="5" TextAlignment="Right" TextChanged="OnVoiceValueTextChanged" />
                                    </Grid>
                                    <Slider x:Name="GateThresholdSlider" Minimum="-100" Maximum="100" Value="0" StepFrequency="1" ValueChanged="OnVoiceSettingsChanged" />
                                </StackPanel>

                                <StackPanel Grid.Row="0" Grid.Column="2" Spacing="6">
                                    <Grid ColumnSpacing="8">
                                        <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="70" /></Grid.ColumnDefinitions>
                                        <TextBlock x:Name="CompressorThresholdLabel" Text="Compressor" FontWeight="SemiBold" VerticalAlignment="Center" />
                                        <TextBox Grid.Column="1" x:Name="CompressorThresholdValueBox" Text="0" MaxLength="5" TextAlignment="Right" TextChanged="OnVoiceValueTextChanged" />
                                    </Grid>
                                    <Slider x:Name="CompressorThresholdSlider" Minimum="-100" Maximum="100" Value="0" StepFrequency="1" ValueChanged="OnVoiceSettingsChanged" />
                                </StackPanel>

                                <StackPanel Grid.Row="0" Grid.Column="3" Spacing="6">
                                    <Grid ColumnSpacing="8">
                                        <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="70" /></Grid.ColumnDefinitions>
                                        <TextBlock x:Name="PitchLabel" Text="Pitch" FontWeight="SemiBold" VerticalAlignment="Center" />
                                        <TextBox Grid.Column="1" x:Name="PitchValueBox" Text="0" MaxLength="5" TextAlignment="Right" TextChanged="OnVoiceValueTextChanged" />
                                    </Grid>
                                    <Slider x:Name="PitchSlider" Minimum="-100" Maximum="100" Value="0" StepFrequency="1" ValueChanged="OnVoiceSettingsChanged" />
                                </StackPanel>

                                <StackPanel Grid.Row="1" Grid.Column="0" Spacing="6">
                                    <Grid ColumnSpacing="8">
                                        <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="70" /></Grid.ColumnDefinitions>
                                        <TextBlock x:Name="FormantLabel" Text="Formant" FontWeight="SemiBold" VerticalAlignment="Center" />
                                        <TextBox Grid.Column="1" x:Name="FormantValueBox" Text="0" MaxLength="5" TextAlignment="Right" TextChanged="OnVoiceValueTextChanged" />
                                    </Grid>
                                    <Slider x:Name="FormantSlider" Minimum="-100" Maximum="100" Value="0" StepFrequency="1" ValueChanged="OnVoiceSettingsChanged" />
                                </StackPanel>

                                <StackPanel Grid.Row="1" Grid.Column="1" Spacing="6">
                                    <Grid ColumnSpacing="8">
                                        <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="70" /></Grid.ColumnDefinitions>
                                        <TextBlock x:Name="BassLabel" Text="Bass" FontWeight="SemiBold" VerticalAlignment="Center" />
                                        <TextBox Grid.Column="1" x:Name="BassValueBox" Text="0" MaxLength="5" TextAlignment="Right" TextChanged="OnVoiceValueTextChanged" />
                                    </Grid>
                                    <Slider x:Name="BassSlider" Minimum="-100" Maximum="100" Value="0" StepFrequency="1" ValueChanged="OnVoiceSettingsChanged" />
                                </StackPanel>

                                <StackPanel Grid.Row="1" Grid.Column="2" Spacing="6">
                                    <Grid ColumnSpacing="8">
                                        <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="70" /></Grid.ColumnDefinitions>
                                        <TextBlock x:Name="TrebleLabel" Text="Treble" FontWeight="SemiBold" VerticalAlignment="Center" />
                                        <TextBox Grid.Column="1" x:Name="TrebleValueBox" Text="0" MaxLength="5" TextAlignment="Right" TextChanged="OnVoiceValueTextChanged" />
                                    </Grid>
                                    <Slider x:Name="TrebleSlider" Minimum="-100" Maximum="100" Value="0" StepFrequency="1" ValueChanged="OnVoiceSettingsChanged" />
                                </StackPanel>

                                <StackPanel Grid.Row="1" Grid.Column="3" Spacing="6">
                                    <Grid ColumnSpacing="8">
                                        <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="70" /></Grid.ColumnDefinitions>
                                        <TextBlock x:Name="DistortionLabel" Text="Distortion" FontWeight="SemiBold" VerticalAlignment="Center" />
                                        <TextBox Grid.Column="1" x:Name="DistortionValueBox" Text="0" MaxLength="5" TextAlignment="Right" TextChanged="OnVoiceValueTextChanged" />
                                    </Grid>
                                    <Slider x:Name="DistortionSlider" Minimum="-100" Maximum="100" Value="0" StepFrequency="1" ValueChanged="OnVoiceSettingsChanged" />
                                </StackPanel>

                                <StackPanel Grid.Row="2" Grid.Column="0" Spacing="6">
                                    <Grid ColumnSpacing="8">
                                        <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="70" /></Grid.ColumnDefinitions>
                                        <TextBlock x:Name="RobotLabel" Text="Robot" FontWeight="SemiBold" VerticalAlignment="Center" />
                                        <TextBox Grid.Column="1" x:Name="RobotValueBox" Text="0" MaxLength="5" TextAlignment="Right" TextChanged="OnVoiceValueTextChanged" />
                                    </Grid>
                                    <Slider x:Name="RobotSlider" Minimum="-100" Maximum="100" Value="0" StepFrequency="1" ValueChanged="OnVoiceSettingsChanged" />
                                </StackPanel>

                                <StackPanel Grid.Row="2" Grid.Column="1" Spacing="6">
                                    <Grid ColumnSpacing="8">
                                        <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="70" /></Grid.ColumnDefinitions>
                                        <TextBlock x:Name="TremoloLabel" Text="Tremolo" FontWeight="SemiBold" VerticalAlignment="Center" />
                                        <TextBox Grid.Column="1" x:Name="TremoloValueBox" Text="0" MaxLength="5" TextAlignment="Right" TextChanged="OnVoiceValueTextChanged" />
                                    </Grid>
                                    <Slider x:Name="TremoloSlider" Minimum="-100" Maximum="100" Value="0" StepFrequency="1" ValueChanged="OnVoiceSettingsChanged" />
                                </StackPanel>

                                <StackPanel Grid.Row="2" Grid.Column="2" Spacing="6">
                                    <Grid ColumnSpacing="8">
                                        <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="70" /></Grid.ColumnDefinitions>
                                        <TextBlock x:Name="EchoLabel" Text="Echo" FontWeight="SemiBold" VerticalAlignment="Center" />
                                        <TextBox Grid.Column="1" x:Name="EchoValueBox" Text="0" MaxLength="5" TextAlignment="Right" TextChanged="OnVoiceValueTextChanged" />
                                    </Grid>
                                    <Slider x:Name="EchoSlider" Minimum="-100" Maximum="100" Value="0" StepFrequency="1" ValueChanged="OnVoiceSettingsChanged" />
                                </StackPanel>

                                <StackPanel Grid.Row="2" Grid.Column="3" Spacing="6">
                                    <Grid ColumnSpacing="8">
                                        <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="70" /></Grid.ColumnDefinitions>
                                        <TextBlock x:Name="ReverbLabel" Text="Reverb" FontWeight="SemiBold" VerticalAlignment="Center" />
                                        <TextBox Grid.Column="1" x:Name="ReverbValueBox" Text="0" MaxLength="5" TextAlignment="Right" TextChanged="OnVoiceValueTextChanged" />
                                    </Grid>
                                    <Slider x:Name="ReverbSlider" Minimum="-100" Maximum="100" Value="0" StepFrequency="1" ValueChanged="OnVoiceSettingsChanged" />
                                </StackPanel>

                                <StackPanel Grid.Row="3" Grid.Column="0" Spacing="6">
                                    <Grid ColumnSpacing="8">
                                        <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="70" /></Grid.ColumnDefinitions>
                                        <TextBlock x:Name="RadioLabel" Text="Radio" FontWeight="SemiBold" VerticalAlignment="Center" />
                                        <TextBox Grid.Column="1" x:Name="RadioValueBox" Text="0" MaxLength="5" TextAlignment="Right" TextChanged="OnVoiceValueTextChanged" />
                                    </Grid>
                                    <Slider x:Name="RadioSlider" Minimum="-100" Maximum="100" Value="0" StepFrequency="1" ValueChanged="OnVoiceSettingsChanged" />
                                </StackPanel>

                                <StackPanel Grid.Row="3" Grid.Column="1" Spacing="6">
                                    <Grid ColumnSpacing="8">
                                        <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="70" /></Grid.ColumnDefinitions>
                                        <TextBlock x:Name="BitCrusherLabel" Text="Bit Crusher" FontWeight="SemiBold" VerticalAlignment="Center" />
                                        <TextBox Grid.Column="1" x:Name="BitCrusherValueBox" Text="0" MaxLength="5" TextAlignment="Right" TextChanged="OnVoiceValueTextChanged" />
                                    </Grid>
                                    <Slider x:Name="BitCrusherSlider" Minimum="-100" Maximum="100" Value="0" StepFrequency="1" ValueChanged="OnVoiceSettingsChanged" />
                                </StackPanel>

                                <StackPanel Grid.Row="3" Grid.Column="2" Spacing="6">
                                    <Grid ColumnSpacing="8">
                                        <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="70" /></Grid.ColumnDefinitions>
                                        <TextBlock x:Name="AlienLabel" Text="Alien" FontWeight="SemiBold" VerticalAlignment="Center" />
                                        <TextBox Grid.Column="1" x:Name="AlienValueBox" Text="0" MaxLength="5" TextAlignment="Right" TextChanged="OnVoiceValueTextChanged" />
                                    </Grid>
                                    <Slider x:Name="AlienSlider" Minimum="-100" Maximum="100" Value="0" StepFrequency="1" ValueChanged="OnVoiceSettingsChanged" />
                                </StackPanel>

                            </Grid>

                            <StackPanel Spacing="12">
                                <TextBlock Text="Presets" FontSize="20" FontWeight="SemiBold" />
                                <VariableSizedWrapGrid x:Name="VoicePresetsPanel"
                                                       Orientation="Horizontal"
                                                       ItemWidth="112"
                                                       ItemHeight="142"
                                                       MaximumRowsOrColumns="8" />
                            </StackPanel>
                        </StackPanel>
                    </ScrollViewer>
                </TabViewItem>

                <TabViewItem Header="Scenes" IsClosable="False">
                    <Grid x:Name="ScenesTabRoot" Padding="0,16,48,24" RowSpacing="14">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0" Spacing="4">
                            <TextBlock Text="Scenes" FontSize="20" FontWeight="SemiBold" />
                            <TextBlock Text="Scene editor: activate scenes, choose a voice preset, set one looped sound, and assign scene-local sound hotkeys." Opacity="0.72" TextWrapping="Wrap" />
                        </StackPanel>

                        <Grid Grid.Row="1" ColumnSpacing="18">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="300" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" Spacing="10">
                                <TextBlock Text="Saved scenes" FontSize="18" FontWeight="SemiBold" />
                                <ListView x:Name="ScenesListView" Height="300" SelectionChanged="OnSceneSelectionChanged">
                                    <ListView.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Padding="4" ColumnSpacing="8">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <StackPanel Grid.Column="0" Spacing="2">
                                                    <TextBlock Text="{Binding Name}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                                                    <TextBlock Text="{Binding SceneListSubtitle}" Opacity="0.65" FontSize="12" TextTrimming="CharacterEllipsis" />
                                                </StackPanel>
                                                <Border Grid.Column="1" Padding="8,2" MinWidth="54" Background="#22FFFFFF" BorderBrush="#44FFFFFF" BorderThickness="1" CornerRadius="8" VerticalAlignment="Center" Opacity="{Binding ActiveOpacity}">
                                                    <TextBlock Text="{Binding ActiveBadge}" FontSize="10" FontWeight="SemiBold" HorizontalAlignment="Center" />
                                                </Border>
                                            </Grid>
                                        </DataTemplate>
                                    </ListView.ItemTemplate>
                                </ListView>
                                <Grid ColumnSpacing="8" RowSpacing="8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <Button Grid.Row="0" Grid.Column="0" x:Name="SceneApplyButton" Content="Apply" HorizontalAlignment="Stretch" Click="OnApplySceneClick" />
                                    <Button Grid.Row="0" Grid.Column="1" x:Name="SceneDisableButton" Content="Disable" HorizontalAlignment="Stretch" Click="OnDisableScenesClick" />
                                    <Button Grid.Row="1" Grid.Column="0" x:Name="SceneDeleteButton" Content="Delete" HorizontalAlignment="Stretch" Click="OnDeleteSceneClick" />
                                    <Button Grid.Row="1" Grid.Column="1" x:Name="SceneRenameButton" Content="Rename" HorizontalAlignment="Stretch" Click="OnRenameSceneClick" />
                                    <Button Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2" x:Name="SceneCreateNewButton" Content="Create New" HorizontalAlignment="Stretch" Click="OnCreateNewSceneClick" />
                                </Grid>
                            </StackPanel>

                            <Border Grid.Column="1" Padding="18">
                                <Grid RowSpacing="16">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="*" />
                                    </Grid.RowDefinitions>

                                    <TextBlock x:Name="SceneDetailsTitleTextBlock" Grid.Row="0" Text="Scene details" FontSize="18" FontWeight="SemiBold" />

                                    <TextBlock Grid.Row="1" Text="Scene Settings" FontSize="16" FontWeight="SemiBold" />

                                    <Grid Grid.Row="2" ColumnSpacing="18">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>

                                        <StackPanel Grid.Column="0" Spacing="8">
                                            <Grid ColumnSpacing="8" VerticalAlignment="Center">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Text="Looped Sound" FontWeight="SemiBold" VerticalAlignment="Center" />
                                                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                                                    <TextBlock Text="HP" Opacity="0.72" FontSize="12" VerticalAlignment="Center" />
                                                    <Slider x:Name="SceneLoopHeadphonesVolumeSlider" Minimum="0" Maximum="1.5" Value="1" StepFrequency="0.01" Width="84" ValueChanged="OnSceneVolumeChanged" />
                                                    <TextBlock x:Name="SceneLoopHeadphonesVolumeValueBox" Text="100%" Opacity="0.72" FontSize="12" Width="36" VerticalAlignment="Center" />
                                                </StackPanel>
                                                <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                                                    <TextBlock Text="Mic" Opacity="0.72" FontSize="12" VerticalAlignment="Center" />
                                                    <Slider x:Name="SceneLoopVirtualMicVolumeSlider" Minimum="0" Maximum="1.5" Value="1" StepFrequency="0.01" Width="84" ValueChanged="OnSceneVolumeChanged" />
                                                    <TextBlock x:Name="SceneLoopVirtualMicVolumeValueBox" Text="100%" Opacity="0.72" FontSize="12" Width="36" VerticalAlignment="Center" />
                                                </StackPanel>
                                            </Grid>
                                            <Grid ColumnSpacing="8">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <Grid Grid.Column="0"
                                                      x:Name="LoopedSceneSoundsPanel"
                                                      Height="88" />
                                                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="4" VerticalAlignment="Top">
                                                    <Button x:Name="SceneLoopPlayLoopButton" Content="∞" Width="42" Height="42" Click="OnSceneLoopPlayLoopClick" ToolTipService.ToolTip="Start loop" />
                                                    <Button x:Name="SceneLoopPlayOnceButton" Content="&#xE768;" FontFamily="Segoe MDL2 Assets" Width="42" Height="42" FontSize="16" Click="OnSceneLoopPlayOnceClick" ToolTipService.ToolTip="Play / pause looped sound" />
                                                    <Button x:Name="SceneLoopRemoveButton" Content="✕" Width="42" Height="42" Click="OnSceneLoopRemoveClick" ToolTipService.ToolTip="Remove sound" />
                                                    <Button x:Name="SceneLoopChooseButton" Content="⮏" Width="42" Height="42" Click="OnSceneLoopChooseClick" ToolTipService.ToolTip="Choose another sound" />
                                                </StackPanel>
                                            </Grid>
                                            <CheckBox x:Name="SceneAutostartLoopsCheckBox"
                                                      Content="Start looped sound when scene is enabled"
                                                      Checked="OnSceneAutostartLoopsChanged"
                                                      Unchecked="OnSceneAutostartLoopsChanged" />
                                        </StackPanel>

                                        <StackPanel Grid.Column="1" Spacing="8">
                                            <TextBlock Text="Voice settings" FontWeight="SemiBold" />
                                            <ComboBox x:Name="SceneVoicePresetComboBox"
                                                      DisplayMemberPath="Name"
                                                      PlaceholderText="Voice preset"
                                                      HorizontalAlignment="Stretch"
                                                      SelectionChanged="OnSceneVoicePresetSelectionChanged" />
                                            <StackPanel Orientation="Horizontal" Spacing="8">
                                                <Button x:Name="SceneVoicePresetClearButton" Content="Clear" MinWidth="78" Click="OnSceneVoicePresetClearClick" />
                                                <Button x:Name="SceneVoicePresetCreateButton" Content="Create new" MinWidth="104" Click="OnSceneVoicePresetCreateClick" />
                                                <Button x:Name="SceneVoiceMonitorButton"
                                                        Content="Voice Monitor: Off"
                                                        MinWidth="150"
                                                        Click="OnToggleVoiceMonitorClick" />
                                            </StackPanel>
                                        </StackPanel>
                                    </Grid>

                                    <Grid Grid.Row="3" RowSpacing="8">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="*" />
                                        </Grid.RowDefinitions>
                                        <Grid Grid.Row="0" ColumnSpacing="10" VerticalAlignment="Center">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="Scene sound buttons" FontSize="16" FontWeight="SemiBold" VerticalAlignment="Center" />
                                        </Grid>
                                        <ScrollViewer x:Name="SceneSoundButtonsScrollViewer" Grid.Row="1" VerticalScrollBarVisibility="Auto" VerticalScrollMode="Enabled" HorizontalScrollBarVisibility="Disabled" HorizontalScrollMode="Disabled" ZoomMode="Disabled">
                                            <VariableSizedWrapGrid x:Name="SceneSoundsPanel"
                                                                   Orientation="Horizontal"
                                                                   ItemWidth="262"
                                                                   ItemHeight="122"
                                                                   MaximumRowsOrColumns="6" />
                                        </ScrollViewer>
                                    </Grid>
                                </Grid>
                            </Border>
                        </Grid>
                    </Grid>
                </TabViewItem>

                <TabViewItem Header="Settings" IsClosable="False">
                    <ScrollViewer x:Name="SettingsScrollViewer" VerticalScrollBarVisibility="Auto" VerticalScrollMode="Enabled" HorizontalScrollBarVisibility="Disabled" HorizontalScrollMode="Disabled" ZoomMode="Disabled">
                        <Grid x:Name="SettingsTabRoot" Padding="0,16,24,24" ColumnSpacing="20">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="5*" MinWidth="360" />
                                <ColumnDefinition Width="4*" MinWidth="320" />
                                <ColumnDefinition Width="3*" MinWidth="260" />
                            </Grid.ColumnDefinitions>

                            <StackPanel x:Name="MainSettings" Grid.Column="0" Spacing="18">
                                <Border x:Name="VBCableNoticeBorder" Background="#22141414" BorderBrush="#55D68B00" BorderThickness="1" CornerRadius="12" Padding="14">
                                    <StackPanel Spacing="8">
                                        <TextBlock Text="Virtual microphone bridge" FontSize="18" FontWeight="SemiBold" />
                                        <TextBlock x:Name="VBCableStatusTextBlock" Text="VB-CABLE is not installed." TextWrapping="WrapWholeWords" Opacity="0.92" FontWeight="SemiBold" />
                                        <TextBlock x:Name="VBCableBridgeInfoTextBlock" Text="Install VB-CABLE to create the virtual microphone bridge. The audio engine will stay disabled until CABLE Input is detected." TextWrapping="WrapWholeWords" Opacity="0.72" />
                                        <StackPanel Orientation="Horizontal" Spacing="10">
                                            <Button x:Name="InstallVBCableButton" Content="Install VB-CABLE" Padding="14,6" MinHeight="32" Click="OnInstallVBCableClick" />
                                            <Button Content="Refresh Devices" Padding="14,6" MinHeight="32" Click="OnRefreshDevicesClick" />
                                        </StackPanel>
                                    </StackPanel>
                                </Border>

                                <TextBlock Text="Audio devices" FontSize="18" FontWeight="SemiBold" />

                                <Grid HorizontalAlignment="Stretch" ColumnSpacing="18">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Button Grid.Column="0" Content="Refresh Devices" Click="OnRefreshDevicesClick" VerticalAlignment="Center" />
                                    <StackPanel Grid.Column="1" Spacing="6" VerticalAlignment="Center">
                                        <TextBlock x:Name="VirtualOutputVolumeLabel" Text="Virtual Mic Master: 100%" FontWeight="SemiBold" />
                                        <Slider x:Name="VirtualOutputVolumeSlider" Minimum="0" Maximum="1.5" Value="1" StepFrequency="0.01" ValueChanged="OnOutputVolumeChanged" />
                                    </StackPanel>
                                </Grid>

                                <StackPanel Spacing="6">
                                    <TextBlock Text="Input Microphone" />
                                    <ComboBox x:Name="InputDeviceComboBox" PlaceholderText="Choose microphone" DisplayMemberPath="FriendlyName" HorizontalAlignment="Stretch" SelectionChanged="OnRouteSettingChanged" />
                                </StackPanel>
                                <ComboBox x:Name="VirtualOutputComboBox" PlaceholderText="Choose CABLE Input" DisplayMemberPath="FriendlyName" HorizontalAlignment="Stretch" SelectionChanged="OnRouteSettingChanged" Visibility="Collapsed" />
                                <StackPanel Spacing="6">
                                    <TextBlock Text="Monitor Output" />
                                    <ComboBox x:Name="MonitorOutputComboBox" PlaceholderText="Choose headphones" DisplayMemberPath="FriendlyName" HorizontalAlignment="Stretch" SelectionChanged="OnRouteSettingChanged" />
                                </StackPanel>

                                <TextBlock Text="Output" FontSize="18" FontWeight="SemiBold" />
                                <StackPanel x:Name="SettingsLogArea" Orientation="Horizontal" Spacing="10" Background="Transparent">
                                    <Button Content="Open logs" Padding="14,6" MinHeight="32" Click="OnOpenLogFullscreenClick" />
                                    <TextBlock Text="Application log opens in a separate window." VerticalAlignment="Center" Opacity="0.7" />
                                </StackPanel>

                                <TextBlock Text="Hotkeys" FontSize="18" FontWeight="SemiBold" />
                                <StackPanel Spacing="8" Background="Transparent">
                                    <StackPanel Orientation="Horizontal" Spacing="10">
                                        <Button Content="Hotkeys" Padding="14,6" MinHeight="32" Click="OnConfigureTransportHotkeysClick" />
                                        <TextBlock Text="Transport and Virtual Mic Mute hotkeys. While a scene is active, Play/Pause and Stop control only scene one-shot sounds." VerticalAlignment="Center" Opacity="0.7" TextWrapping="WrapWholeWords" />
                                    </StackPanel>
                                    <TextBlock x:Name="TransportHotkeysSummaryTextBlock" Text="Transport hotkeys: not configured" Opacity="0.72" TextWrapping="Wrap" />
                                </StackPanel>

                                <TextBlock Text="SoundBoard" FontSize="18" FontWeight="SemiBold" />
                                <StackPanel Spacing="8">
                                    <TextBlock x:Name="DelayLabel" Text="SoundBoard Virtual Mic Delay: 85 ms" FontWeight="SemiBold" />
                                    <Slider x:Name="SoundVirtualDelaySlider" Minimum="0" Maximum="300" Value="85" StepFrequency="1" ValueChanged="OnDelayChanged" />
                                    <TextBlock Text="SoundBoard plays in headphones immediately, then reaches the virtual microphone bridge after this delay. Changes apply on next Play Sound." Opacity="0.7" TextWrapping="Wrap" />
                                </StackPanel>

                                <TextBlock Text="Engine manual control" FontSize="18" FontWeight="SemiBold" />
                                <StackPanel Spacing="8">
                                    <Grid ColumnSpacing="10" VerticalAlignment="Center">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Engine status" Opacity="0.72" VerticalAlignment="Center" />
                                        <TextBlock Grid.Column="1" x:Name="EngineStatusTextBlock" Text="Stopped" Opacity="0.9" FontWeight="SemiBold" VerticalAlignment="Center" />
                                    </Grid>
                                    <TextBlock Text="The engine starts automatically when VoiSee opens. Use these buttons only for manual troubleshooting." Opacity="0.7" TextWrapping="Wrap" />
                                    <StackPanel Orientation="Horizontal" Spacing="10">
                                        <Button x:Name="StartEngineButton" Content="Start Engine" MinWidth="154" Height="42" Padding="18,8" Click="OnStartEngineClick" />
                                        <Button x:Name="StopEngineButton" Content="Stop Engine" MinWidth="154" Height="42" Padding="18,8" Click="OnStopEngineClick" />
                                    </StackPanel>
                                </StackPanel>
                            </StackPanel>

                            <Border x:Name="SettingsThemesPanel" Grid.Column="1" Background="#08000000" BorderBrush="#22FFFFFF" BorderThickness="1" CornerRadius="12" Padding="18" VerticalAlignment="Top">
                                <StackPanel Spacing="12">
                                    <TextBlock Text="Appearance / Themes" FontSize="18" FontWeight="SemiBold" />
                                    <TextBlock Text="Create a .voiseetheme.css file, edit it, save it, and VoiSee will apply it automatically. New theme files start as a non-destructive template, so the current design does not change until you edit active declarations." TextWrapping="WrapWholeWords" Opacity="0.72" />
                                    <StackPanel Spacing="6">
                                        <TextBlock Text="Current theme" Opacity="0.72" />
                                        <ComboBox x:Name="ThemeComboBox" HorizontalAlignment="Stretch" SelectionChanged="OnThemeSelectionChanged" DropDownOpened="OnThemeComboBoxDropDownOpened" />
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Spacing="10">
                                        <Button Content="Create New Theme" Padding="14,6" MinHeight="32" Click="OnCreateNewThemeClick" />
                                        <Button Content="Open Theme File" Padding="14,6" MinHeight="32" Click="OnOpenThemeFileClick" />
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Spacing="10">
                                        <Button Content="Open Theme Folder" Padding="14,6" MinHeight="32" Click="OnOpenThemeFolderClick" />
                                        <Button x:Name="RenameThemeButton" Content="Rename Theme" Padding="14,6" MinHeight="32" IsEnabled="False" Click="OnRenameThemeClick" />
                                        <Button x:Name="DeleteThemeButton" Content="Delete Theme" Padding="14,6" MinHeight="32" IsEnabled="False" Click="OnDeleteThemeClick" />
                                    </StackPanel>
                                    <TextBlock x:Name="ThemeStatusTextBlock" Text="Theme: Default Dark" TextWrapping="WrapWholeWords" Opacity="0.72" />
                                    <TextBlock Text="Selector prefixes: Pn = panels, Bt = buttons, Sl = sliders, Cb = combo boxes, Txt = text. Examples: #PnMainHeader, .Bt, #BtSettingsMute, #SlSettingsVirtualMicMaster, #CbTheme. For sliders use height/min-height/margin; padding may be ignored by WinUI Slider." TextWrapping="WrapWholeWords" Opacity="0.62" />
                                </StackPanel>
                            </Border>

                            <Border x:Name="AboutMePanel" Grid.Column="2" Background="#08000000" BorderBrush="#22FFFFFF" BorderThickness="1" CornerRadius="12" Padding="18" VerticalAlignment="Top">
                                <StackPanel Spacing="14">
                                    <TextBlock Text="About me" FontSize="18" FontWeight="SemiBold" />
                                    <TextBlock Text="Links" Opacity="0.72" />

                                    <StackPanel Spacing="8">
                                        <TextBlock Text="Telegram" FontWeight="SemiBold" />
                                        <HyperlinkButton Content="t.me/VoriXq" NavigateUri="https://t.me/VoriXq" HorizontalAlignment="Left" />
                                    </StackPanel>

                                    <StackPanel Spacing="8">
                                        <TextBlock Text="GitHub" FontWeight="SemiBold" />
                                        <HyperlinkButton Content="github.com/VoriX0/VoiSe" NavigateUri="https://github.com/VoriX0/VoiSe" HorizontalAlignment="Left" />
                                    </StackPanel>

                                    <StackPanel Spacing="8">
                                        <TextBlock Text="CloudTips" FontWeight="SemiBold" />
                                        <HyperlinkButton Content="pay.cloudtips.ru/p/00d81ea7" NavigateUri="https://pay.cloudtips.ru/p/00d81ea7" HorizontalAlignment="Left" />
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </ScrollViewer>
                </TabViewItem>
                </TabView>
            </Border>

        </Grid>
        </Grid>
</Grid>
</Window>
