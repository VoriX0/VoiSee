                        </StackPanel>
                    </ScrollViewer>
                </TabViewItem>

                <TabViewItem Header="Scenes" IsClosable="False">
                    <Grid x:Name="ScenesTabRoot" Padding="0,16,48,24" RowSpacing="14">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0" Spacing="4">
                            <TextBlock Text="Scenes" FontSize="20" FontWeight="SemiBold" />
                            <TextBlock Text="Scene editor: activate scenes, choose a voice preset, set one looped sound, and assign scene-local sound hotkeys." Opacity="0.72" TextWrapping="Wrap" />
                        </StackPanel>

                        <Grid Grid.Row="1" ColumnSpacing="18">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="300" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" Spacing="10">
                                <TextBlock Text="Saved scenes" FontSize="18" FontWeight="SemiBold" />
                                <ListView Style="{ThemeResource VoiSee.Style.ListView}" ItemContainerStyle="{ThemeResource VoiSee.Style.ListViewItem}" x:Name="ScenesListView" Height="300" SelectionChanged="OnSceneSelectionChanged">
                                    <ListView.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Padding="4" ColumnSpacing="8">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <StackPanel Grid.Column="0" Spacing="2">
                                                    <TextBlock Text="{Binding Name}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                                                    <TextBlock Text="{Binding SceneListSubtitle}" Opacity="0.65" FontSize="12" TextTrimming="CharacterEllipsis" />
                                                </StackPanel>
                                                <Border Grid.Column="1" Padding="8,2" MinWidth="54" Background="{ThemeResource VoiSee.CardValueBackgroundBrush}" BorderBrush="{ThemeResource VoiSee.CardValueBorderBrush}" BorderThickness="1" CornerRadius="{ThemeResource VoiSee.CornerRadius.Medium}" VerticalAlignment="Center" Opacity="{Binding ActiveOpacity}">
                                                    <TextBlock Text="{Binding ActiveBadge}" FontSize="10" FontWeight="SemiBold" HorizontalAlignment="Center" />
                                                </Border>
                                            </Grid>
                                        </DataTemplate>
                                    </ListView.ItemTemplate>
                                </ListView>
                                <Grid ColumnSpacing="8" RowSpacing="8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <Button Style="{ThemeResource VoiSee.Style.Button.SceneAction}" Grid.Row="0" Grid.Column="0" x:Name="SceneApplyButton" Content="Apply" HorizontalAlignment="Stretch" Click="OnApplySceneClick" />
                                    <Button Style="{ThemeResource VoiSee.Style.Button.SceneAction}" Grid.Row="0" Grid.Column="1" x:Name="SceneDisableButton" Content="Disable" HorizontalAlignment="Stretch" Click="OnDisableScenesClick" />
                                    <Button Style="{ThemeResource VoiSee.Style.Button.SceneAction}" Grid.Row="1" Grid.Column="0" x:Name="SceneDeleteButton" Content="Delete" HorizontalAlignment="Stretch" Click="OnDeleteSceneClick" />
                                    <Button Style="{ThemeResource VoiSee.Style.Button.SceneAction}" Grid.Row="1" Grid.Column="1" x:Name="SceneRenameButton" Content="Rename" HorizontalAlignment="Stretch" Click="OnRenameSceneClick" />
                                    <Button Style="{ThemeResource VoiSee.Style.Button.SceneAction}" Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2" x:Name="SceneCreateNewButton" Content="Create New" HorizontalAlignment="Stretch" Click="OnCreateNewSceneClick" />
                                </Grid>
                            </StackPanel>

                            <Border Grid.Column="1" Padding="18">
                                <Grid RowSpacing="16">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="*" />
                                    </Grid.RowDefinitions>

                                    <TextBlock x:Name="SceneDetailsTitleTextBlock" Grid.Row="0" Text="Scene details" FontSize="18" FontWeight="SemiBold" />

                                    <TextBlock Grid.Row="1" Text="Scene Settings" FontSize="16" FontWeight="SemiBold" />

                                    <Grid Grid.Row="2" ColumnSpacing="18">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>

                                        <StackPanel Grid.Column="0" Spacing="8">
                                            <Grid ColumnSpacing="8" VerticalAlignment="Center">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Text="Looped Sound" FontWeight="SemiBold" VerticalAlignment="Center" />
                                                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                                                    <TextBlock Text="HP" Opacity="0.72" FontSize="12" VerticalAlignment="Center" />
                                                    <Slider Style="{ThemeResource VoiSee.Style.Slider}" x:Name="SceneLoopHeadphonesVolumeSlider" Minimum="0" Maximum="1.5" Value="1" StepFrequency="0.01" Width="84" ValueChanged="OnSceneVolumeChanged" />
                                                    <TextBlock x:Name="SceneLoopHeadphonesVolumeValueBox" Text="100%" Opacity="0.72" FontSize="12" Width="36" VerticalAlignment="Center" />
                                                </StackPanel>
                                                <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                                                    <TextBlock Text="Mic" Opacity="0.72" FontSize="12" VerticalAlignment="Center" />
                                                    <Slider Style="{ThemeResource VoiSee.Style.Slider}" x:Name="SceneLoopVirtualMicVolumeSlider" Minimum="0" Maximum="1.5" Value="1" StepFrequency="0.01" Width="84" ValueChanged="OnSceneVolumeChanged" />
                                                    <TextBlock x:Name="SceneLoopVirtualMicVolumeValueBox" Text="100%" Opacity="0.72" FontSize="12" Width="36" VerticalAlignment="Center" />
                                                </StackPanel>
                                            </Grid>
                                            <Grid ColumnSpacing="8">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <Grid Grid.Column="0"
                                                      x:Name="LoopedSceneSoundsPanel"
                                                      Height="88" />
                                                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="4" VerticalAlignment="Top">
                                                    <Button Style="{ThemeResource VoiSee.Style.Button}" x:Name="SceneLoopPlayLoopButton" Content="∞" Width="42" Height="42" Click="OnSceneLoopPlayLoopClick" ToolTipService.ToolTip="Start loop" />
                                                    <Button Style="{ThemeResource VoiSee.Style.Button}" x:Name="SceneLoopPlayOnceButton" Content="&#xE768;" FontFamily="Segoe MDL2 Assets" Width="42" Height="42" FontSize="16" Click="OnSceneLoopPlayOnceClick" ToolTipService.ToolTip="Play / pause looped sound" />
                                                    <Button Style="{ThemeResource VoiSee.Style.Button}" x:Name="SceneLoopRemoveButton" Content="✕" Width="42" Height="42" Click="OnSceneLoopRemoveClick" ToolTipService.ToolTip="Remove sound" />
                                                    <Button Style="{ThemeResource VoiSee.Style.Button}" x:Name="SceneLoopChooseButton" Content="⮏" Width="42" Height="42" Click="OnSceneLoopChooseClick" ToolTipService.ToolTip="Choose another sound" />
                                                </StackPanel>
                                            </Grid>
                                            <CheckBox Style="{ThemeResource VoiSee.Style.CheckBox}" x:Name="SceneAutostartLoopsCheckBox"
                                                      Content="Start looped sound when scene is enabled"
                                                      Checked="OnSceneAutostartLoopsChanged"
                                                      Unchecked="OnSceneAutostartLoopsChanged" />
                                        </StackPanel>

                                        <StackPanel Grid.Column="1" Spacing="8">
                                            <TextBlock Text="Voice settings" FontWeight="SemiBold" />
                                            <ComboBox Style="{ThemeResource VoiSee.Style.ComboBox}" x:Name="SceneVoicePresetComboBox"
                                                      DisplayMemberPath="Name"
                                                      PlaceholderText="Voice preset"
                                                      HorizontalAlignment="Stretch"
                                                      SelectionChanged="OnSceneVoicePresetSelectionChanged" />
                                            <StackPanel Orientation="Horizontal" Spacing="8">
                                                <Button Style="{ThemeResource VoiSee.Style.Button}" x:Name="SceneVoicePresetClearButton" Content="Clear" MinWidth="78" Click="OnSceneVoicePresetClearClick" />
                                                <Button Style="{ThemeResource VoiSee.Style.Button}" x:Name="SceneVoicePresetCreateButton" Content="Create new" MinWidth="104" Click="OnSceneVoicePresetCreateClick" />
                                                <Button Style="{ThemeResource VoiSee.Style.Button}" x:Name="SceneVoiceMonitorButton"
                                                        Content="Voice Monitor: Off"
                                                        MinWidth="150"
                                                        Click="OnToggleVoiceMonitorClick" />
                                            </StackPanel>
                                        </StackPanel>
                                    </Grid>

                                    <Grid Grid.Row="3" RowSpacing="8">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="*" />
                                        </Grid.RowDefinitions>
                                        <Grid Grid.Row="0" ColumnSpacing="10" VerticalAlignment="Center">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="Scene sound buttons" FontSize="16" FontWeight="SemiBold" VerticalAlignment="Center" />
                                        </Grid>
                                        <ScrollViewer x:Name="SceneSoundButtonsScrollViewer" Grid.Row="1" VerticalScrollBarVisibility="Auto" VerticalScrollMode="Enabled" HorizontalScrollBarVisibility="Disabled" HorizontalScrollMode="Disabled" ZoomMode="Disabled">
                                            <VariableSizedWrapGrid x:Name="SceneSoundsPanel"
                                                                   Orientation="Horizontal"
                                                                   ItemWidth="262"
                                                                   ItemHeight="122"
                                                                   MaximumRowsOrColumns="6" />
                                        </ScrollViewer>
                                    </Grid>
                                </Grid>
                            </Border>
                        </Grid>
                    </Grid>
                </TabViewItem>

                <TabViewItem x:Name="MediaBridgeTabViewItem" Header="Media Bridge" IsClosable="False">
                    <Grid x:Name="MediaBridgeTabRoot" Padding="0,16,48,24" RowSpacing="14">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0" ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Spacing="4">
                                <TextBlock Text="Media Bridge" FontSize="20" FontWeight="SemiBold" />
                                <TextBlock Text="Capture audio from one application and mix it into the virtual microphone without adding a second headphone monitor." Opacity="0.72" TextWrapping="Wrap" />
                            </StackPanel>
                            <Button Grid.Column="1"
                                    x:Name="MediaBridgeStopButton"
                                    Style="{ThemeResource VoiSee.Style.Button}"
                                    Content="Stop"
                                    MinWidth="92"
                                    VerticalAlignment="Top"
                                    Visibility="Collapsed"
                                    Click="OnMediaBridgeStopClick" />
                        </Grid>

                        <Border Grid.Row="1"
                                Style="{ThemeResource VoiSee.Style.Panel.SettingsCard}"
                                Padding="12"
                                MinHeight="360">
                            <Grid Background="{ThemeResource VoiSee.AppBackgroundBrush}">
                                <Image x:Name="MediaBridgePreviewImage"
                                       Stretch="Uniform"
                                       HorizontalAlignment="Stretch"
                                       VerticalAlignment="Stretch" />
                                <StackPanel x:Name="MediaBridgePreviewPlaceholder"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center"
                                            Spacing="12">
                                    <FontIcon Glyph="&#xE7F4;" FontSize="54" Opacity="0.62" />
                                    <TextBlock Text="Select a window to preview its source"
                                               FontSize="18"
                                               FontWeight="SemiBold"
                                               HorizontalAlignment="Center" />
                                    <TextBlock x:Name="MediaBridgeSavedProfileTextBlock"
                                               Text="No saved media profile"
                                               Style="{ThemeResource VoiSee.Style.Text.Secondary}"
                                               TextAlignment="Center"
                                               TextWrapping="Wrap"
                                               MaxWidth="560" />
                                </StackPanel>
                            </Grid>
                        </Border>

                        <Border Grid.Row="2" Style="{ThemeResource VoiSee.Style.Panel.SettingsCard}">
                            <Grid RowSpacing="14">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <Grid Grid.Row="0" ColumnSpacing="16">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" Spacing="3">
                                        <TextBlock x:Name="MediaBridgeSourceTitleTextBlock"
                                                   Text="No window selected"
                                                   FontSize="18"
                                                   FontWeight="SemiBold"
                                                   TextTrimming="CharacterEllipsis" />
                                        <TextBlock x:Name="MediaBridgeSourceDetailsTextBlock"
                                                   Text="Choose an application window. VoiSee will not reconnect to it automatically after restart."
                                                   Style="{ThemeResource VoiSee.Style.Text.Secondary}"
                                                   TextWrapping="Wrap" />
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" Spacing="3" HorizontalAlignment="Right">
                                        <TextBlock x:Name="MediaBridgeStatusTextBlock"
                                                   Text="Not selected"
                                                   FontWeight="SemiBold"
                                                   HorizontalAlignment="Right" />
                                        <TextBlock x:Name="MediaBridgeDurationTextBlock"
                                                   Text="00:00:00"
                                                   Style="{ThemeResource VoiSee.Style.Text.Secondary}"
                                                   HorizontalAlignment="Right" />
                                    </StackPanel>
                                </Grid>

                                <Grid Grid.Row="1" ColumnSpacing="12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Button Grid.Column="0"
                                            x:Name="MediaBridgeSelectWindowButton"
                                            Style="{ThemeResource VoiSee.Style.Button}"
                                            Content="Select Window"
                                            MinWidth="126"
                                            Click="OnMediaBridgeSelectWindowClick" />
                                    <Button Grid.Column="1"
                                            x:Name="MediaBridgeStartButton"
                                            Style="{ThemeResource VoiSee.Style.Button}"
                                            Content="Start Broadcast"
                                            MinWidth="132"
                                            IsEnabled="False"
                                            Click="OnMediaBridgeStartClick" />
                                    <Button Grid.Column="2"
                                            x:Name="MediaBridgePauseButton"
                                            Style="{ThemeResource VoiSee.Style.Button}"
                                            Content="Pause"
                                            MinWidth="100"
                                            IsEnabled="False"
                                            Click="OnMediaBridgePauseResumeClick" />
                                    <StackPanel Grid.Column="3" Spacing="5" VerticalAlignment="Center">
                                        <Grid ColumnSpacing="10">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="Source level" VerticalAlignment="Center" />
                                            <ProgressBar Grid.Column="1"
                                                         x:Name="MediaBridgeLevelProgressBar"
                                                         Minimum="0"
                                                         Maximum="1"
                                                         Value="0"
                                                         Height="8"
                                                         VerticalAlignment="Center" />
                                            <TextBlock Grid.Column="2"
                                                       x:Name="MediaBridgeLevelTextBlock"
                                                       Text="Silent"
                                                       Width="56"
                                                       TextAlignment="Right"
                                                       Style="{ThemeResource VoiSee.Style.Text.Secondary}"
                                                       VerticalAlignment="Center" />
                                        </Grid>
                                    </StackPanel>
                                </Grid>

                                <Grid Grid.Row="2" ColumnSpacing="14">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0"
                                               Text="Volume in Microphone"
                                               FontWeight="SemiBold"
                                               VerticalAlignment="Center" />
                                    <Slider Grid.Column="1"
                                            x:Name="MediaBridgeVolumeSlider"
                                            Style="{ThemeResource VoiSee.Style.Slider}"
                                            Minimum="0"
                                            Maximum="1.5"
                                            Value="1"
                                            StepFrequency="0.01"
                                            ValueChanged="OnMediaBridgeVolumeChanged" />
                                    <TextBlock Grid.Column="2"
                                               x:Name="MediaBridgeVolumeValueTextBlock"
                                               Text="100%"
                                               Width="52"
                                               TextAlignment="Right"
                                               VerticalAlignment="Center" />
                                </Grid>
                            </Grid>
                        </Border>
                    </Grid>
                </TabViewItem>

                <TabViewItem Header="Settings" IsClosable="False">
                    <ScrollViewer x:Name="SettingsScrollViewer"
                                  VerticalScrollBarVisibility="Auto"
                                  VerticalScrollMode="Enabled"
                                  HorizontalScrollBarVisibility="Disabled"
                                  HorizontalScrollMode="Disabled"
                                  ZoomMode="Disabled">
                        <Grid x:Name="SettingsTabRoot"
                              Padding="0,16,24,24"
                              ColumnSpacing="20"
                              RowSpacing="20"
                              SizeChanged="OnSettingsTabRootSizeChanged">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition x:Name="SettingsSystemColumn" Width="5*" MinWidth="360" />
                                <ColumnDefinition x:Name="SettingsThemesColumn" Width="4*" MinWidth="320" />
                                <ColumnDefinition x:Name="SettingsAboutColumn" Width="3*" MinWidth="260" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <StackPanel x:Name="MainSettings" Grid.Column="0" Grid.Row="0" Spacing="18">
                                <TextBlock Text="System &amp; Audio" FontSize="22" FontWeight="SemiBold" />

                                <Border x:Name="VBCableNoticeBorder"
                                        Background="{ThemeResource VoiSee.VBCableNoticeBackgroundBrush}"
                                        BorderBrush="{ThemeResource VoiSee.VBCableNoticeBorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="{ThemeResource VoiSee.CornerRadius.Large}"
                                        Padding="14">
                                    <StackPanel Spacing="8">
                                        <TextBlock Text="VB-CABLE status" FontSize="18" FontWeight="SemiBold" />
                                        <TextBlock x:Name="VBCableStatusTextBlock"
                                                   Text="VB-CABLE is not installed."
                                                   TextWrapping="WrapWholeWords"
                                                   Opacity="0.92"
                                                   FontWeight="SemiBold" />
                                        <TextBlock Style="{ThemeResource VoiSee.Style.Text.Secondary}"
                                                   x:Name="VBCableBridgeInfoTextBlock"
                                                   Text="Install VB-CABLE to create the virtual microphone bridge. The audio engine will stay disabled until CABLE Input is detected."
                                                   TextWrapping="WrapWholeWords"
                                                   Opacity="0.72" />
                                        <StackPanel Orientation="Horizontal" Spacing="10">
                                            <Button Style="{ThemeResource VoiSee.Style.Button.SettingsAction}"
                                                    x:Name="InstallVBCableButton"
                                                    Content="Install VB-CABLE"
                                                    Padding="14,6"
                                                    MinHeight="32"
                                                    Click="OnInstallVBCableClick" />
                                            <Button Style="{ThemeResource VoiSee.Style.Button}"
                                                    Content="Refresh Devices"
                                                    Padding="14,6"
                                                    MinHeight="32"
                                                    Click="OnRefreshDevicesClick" />
                                        </StackPanel>
                                    </StackPanel>
                                </Border>

                                <Border Style="{ThemeResource VoiSee.Style.Panel.SettingsCard}">
                                    <StackPanel Spacing="12">
                                        <Grid ColumnSpacing="12">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="Audio Devices" FontSize="18" FontWeight="SemiBold" VerticalAlignment="Center" />
                                            <Button Grid.Column="1"
                                                    Style="{ThemeResource VoiSee.Style.Button}"
                                                    Content="Refresh Devices"
                                                    Padding="14,6"
                                                    MinHeight="32"
                                                    Click="OnRefreshDevicesClick" />
                                        </Grid>

                                        <StackPanel Spacing="6">
                                            <TextBlock Text="Input Device" />
                                            <ComboBox Style="{ThemeResource VoiSee.Style.ComboBox}"
                                                      x:Name="InputDeviceComboBox"
                                                      PlaceholderText="Choose microphone"
                                                      DisplayMemberPath="FriendlyName"
                                                      HorizontalAlignment="Stretch"
                                                      SelectionChanged="OnRouteSettingChanged" />
                                        </StackPanel>

                                        <StackPanel Spacing="6">
                                            <TextBlock Text="Monitor / Headphones" />
                                            <ComboBox Style="{ThemeResource VoiSee.Style.ComboBox}"
                                                      x:Name="MonitorOutputComboBox"
                                                      PlaceholderText="Choose headphones"
                                                      DisplayMemberPath="FriendlyName"
                                                      HorizontalAlignment="Stretch"
                                                      SelectionChanged="OnRouteSettingChanged" />
                                        </StackPanel>

                                        <StackPanel Spacing="6">
                                            <TextBlock x:Name="VirtualOutputVolumeLabel" Text="Virtual Mic Master: 100%" FontWeight="SemiBold" />
                                            <Slider Style="{ThemeResource VoiSee.Style.Slider}"
                                                    x:Name="VirtualOutputVolumeSlider"
                                                    Minimum="0"
                                                    Maximum="1.5"
                                                    Value="1"
                                                    StepFrequency="0.01"
                                                    ValueChanged="OnOutputVolumeChanged" />
                                        </StackPanel>

                                        <StackPanel Spacing="6">
                                            <TextBlock x:Name="DelayLabel" Text="SoundBoard Delay: 85 ms" FontWeight="SemiBold" />
                                            <Slider Style="{ThemeResource VoiSee.Style.Slider}"
                                                    x:Name="SoundVirtualDelaySlider"
                                                    Minimum="0"
                                                    Maximum="300"
                                                    Value="85"
                                                    StepFrequency="1"
                                                    ValueChanged="OnDelayChanged" />
                                            <TextBlock Text="SoundBoard reaches headphones immediately and the virtual microphone after this delay. Changes apply on the next playback."
                                                       Opacity="0.7"
                                                       TextWrapping="WrapWholeWords" />
                                        </StackPanel>
                                    </StackPanel>
                                </Border>

                                <Border Style="{ThemeResource VoiSee.Style.Panel.SettingsCard}">
                                    <StackPanel Spacing="10">
                                        <TextBlock Text="Hotkeys" FontSize="18" FontWeight="SemiBold" />
                                        <Button Style="{ThemeResource VoiSee.Style.Button}"
                                                Content="Configure Hotkeys"
                                                HorizontalAlignment="Left"
                                                Padding="14,6"
                                                MinHeight="32"
                                                Click="OnConfigureTransportHotkeysClick" />
                                        <TextBlock Style="{ThemeResource VoiSee.Style.Text.Secondary}"
                                                   x:Name="TransportHotkeysSummaryTextBlock"
                                                   Text="Transport hotkeys: not configured"
                                                   Opacity="0.72"
                                                   TextWrapping="Wrap" />
                                        <TextBlock Text="NumPad is supported. Conflicts follow this priority: Transport → Scene → SoundBoard → Voice Preset. Sound Editor keeps its dedicated Play/Pause and Stop behavior."
                                                   Opacity="0.66"
                                                   TextWrapping="WrapWholeWords" />
                                    </StackPanel>
                                </Border>

                                <Border Style="{ThemeResource VoiSee.Style.Panel.SettingsCard}">
                                    <StackPanel Spacing="8">
                                        <TextBlock Text="Startup" FontSize="18" FontWeight="SemiBold" />
                                        <CheckBox Style="{ThemeResource VoiSee.Style.CheckBox}"
                                                  x:Name="StartWithWindowsCheckBox"
                                                  Content="Start VoiSee with Windows"
                                                  Checked="OnStartWithWindowsChanged"
                                                  Unchecked="OnStartWithWindowsChanged" />
                                        <TextBlock Text="VoiSee starts in the notification area and keeps audio hotkeys available."
                                                   Opacity="0.7"
                                                   TextWrapping="WrapWholeWords" />
                                    </StackPanel>
                                </Border>

                                <!-- These named controls remain hidden because the established engine state code updates them. -->
                                <StackPanel Visibility="Collapsed">
                                    <!-- Internal automatic VB-CABLE route. It is intentionally not user-configurable. -->
                                    <ComboBox x:Name="VirtualOutputComboBox"
                                              DisplayMemberPath="FriendlyName"
                                              SelectionChanged="OnRouteSettingChanged" />
                                    <TextBlock x:Name="EngineStatusTextBlock" Text="Stopped" />
                                    <Button x:Name="StartEngineButton" Content="Start Engine" Click="OnStartEngineClick" />
                                    <Button x:Name="StopEngineButton" Content="Stop Engine" Click="OnStopEngineClick" />
                                </StackPanel>
                            </StackPanel>

                            <Border Style="{ThemeResource VoiSee.Style.Panel.SettingsCard}"
                                    x:Name="SettingsThemesPanel"
                                    Grid.Column="1"
                                    Grid.Row="0"
                                    VerticalAlignment="Top">
                                <StackPanel Spacing="12">
                                    <TextBlock Text="Themes" FontSize="22" FontWeight="SemiBold" />
                                    <TextBlock Text="VoiSee themes are native WinUI ResourceDictionary files with the .voiseetheme.xaml extension. Save a valid dictionary and live reload applies it automatically; invalid XAML leaves the last working theme active."
                                               TextWrapping="WrapWholeWords"
                                               Opacity="0.72" />

                                    <StackPanel Spacing="5">
                                        <TextBlock Text="Themes folder" Opacity="0.72" />
                                        <TextBlock x:Name="ThemeFolderPathTextBlock"
                                                   Text="%LOCALAPPDATA%\VoiSe\themes"
                                                   FontFamily="Consolas"
                                                   FontSize="12"
                                                   TextWrapping="WrapWholeWords"
                                                   IsTextSelectionEnabled="True" />
                                    </StackPanel>

                                    <StackPanel Spacing="6">
                                        <TextBlock Text="Current theme" Opacity="0.72" />
                                        <ComboBox Style="{ThemeResource VoiSee.Style.ComboBox}"
                                                  x:Name="ThemeComboBox"
                                                  HorizontalAlignment="Stretch"
                                                  SelectionChanged="OnThemeSelectionChanged"
                                                  DropDownOpened="OnThemeComboBoxDropDownOpened" />
                                    </StackPanel>

                                    <StackPanel Orientation="Horizontal" Spacing="10">
                                        <Button Style="{ThemeResource VoiSee.Style.Button.ThemeAction}"
                                                Content="Create New Theme"
                                                Padding="14,6"
                                                MinHeight="32"
                                                Click="OnCreateNewThemeClick" />
                                        <Button Style="{ThemeResource VoiSee.Style.Button.ThemeAction}"
                                                x:Name="OpenThemeFileButton"
                                                Content="Open Theme File"
                                                Padding="14,6"
                                                MinHeight="32"
                                                IsEnabled="False"
                                                Click="OnOpenThemeFileClick" />
                                    </StackPanel>

                                    <StackPanel Orientation="Horizontal" Spacing="10">
                                        <Button Style="{ThemeResource VoiSee.Style.Button.ThemeAction}"
                                                Content="Open Theme Folder"
                                                Padding="14,6"
                                                MinHeight="32"
                                                Click="OnOpenThemeFolderClick" />
                                        <Button Style="{ThemeResource VoiSee.Style.Button.ThemeAction}"
                                                x:Name="RenameThemeButton"
                                                Content="Rename Theme"
                                                Padding="14,6"
                                                MinHeight="32"
                                                IsEnabled="False"
                                                Click="OnRenameThemeClick" />
                                        <Button Style="{ThemeResource VoiSee.Style.Button.ThemeAction}"
                                                x:Name="DeleteThemeButton"
                                                Content="Delete Theme"
                                                Padding="14,6"
                                                MinHeight="32"
                                                IsEnabled="False"
                                                Click="OnDeleteThemeClick" />
                                    </StackPanel>

                                    <TextBlock Style="{ThemeResource VoiSee.Style.Text.Secondary}"
                                               x:Name="ThemeStatusTextBlock"
                                               Text="Theme: Default Dark"
                                               TextWrapping="WrapWholeWords"
                                               Opacity="0.72" />
                                    <TextBlock Text="A new theme is an exact editable copy of Default Dark. Keep x:Key names unchanged. Colors, brushes, control states, panel geometry and gradients may be edited directly in XAML."
                                               TextWrapping="WrapWholeWords"
                                               Opacity="0.62" />
                                </StackPanel>
                            </Border>

                            <StackPanel x:Name="SettingsAboutStack"
                                        Grid.Column="2"
                                        Grid.Row="0"
                                        Spacing="20"
                                        VerticalAlignment="Top">
                                <Border Style="{ThemeResource VoiSee.Style.Panel.SettingsCard}"
                                        x:Name="AboutMePanel"
                                        VerticalAlignment="Top">
                                    <StackPanel Spacing="14">
                                        <TextBlock Text="About me" FontSize="22" FontWeight="SemiBold" />
                                        <TextBlock Text="Links" Opacity="0.72" />

                                        <StackPanel Spacing="8">
                                            <TextBlock Text="Telegram" FontWeight="SemiBold" />
                                            <HyperlinkButton Content="t.me/VoriXdev"
                                                             NavigateUri="https://t.me/VoriXdev"
                                                             HorizontalAlignment="Left" />
                                        </StackPanel>

                                        <StackPanel Spacing="8">
                                            <TextBlock Text="GitHub" FontWeight="SemiBold" />
                                            <HyperlinkButton Content="github.com/VoriX0/VoiSe"
                                                             NavigateUri="https://github.com/VoriX0/VoiSe"
                                                             HorizontalAlignment="Left" />
                                        </StackPanel>

                                        <StackPanel Spacing="8">
                                            <TextBlock Text="CloudTips" FontWeight="SemiBold" />
                                            <HyperlinkButton Content="pay.cloudtips.ru/p/00d81ea7"
                                                             NavigateUri="https://pay.cloudtips.ru/p/00d81ea7"
                                                             HorizontalAlignment="Left" />
                                        </StackPanel>
                                    </StackPanel>
                                </Border>

                                <Border Style="{ThemeResource VoiSee.Style.Panel.SettingsCard}"
                                        x:Name="AdvancedSettingsPanel">
                                    <StackPanel Spacing="8">
                                        <TextBlock Text="Advanced Settings" FontSize="18" FontWeight="SemiBold" />
                                        <TextBlock Text="Open manual engine controls and the full application log in one troubleshooting window."
                                                   Opacity="0.7"
                                                   TextWrapping="WrapWholeWords" />
                                        <Button Style="{ThemeResource VoiSee.Style.Button.SettingsAction}"
                                                Content="Open Advanced Settings"
                                                HorizontalAlignment="Stretch"
                                                Padding="16,8"
                                                MinHeight="36"
                                                Click="OnOpenAdvancedSettingsClick" />
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Grid>
                    </ScrollViewer>
                </TabViewItem>

                </TabView>
            </Border>

        </Grid>
        </Grid>

        <!-- VoiSee 10.2: retained full-window external file import target. Size is updated to 75% of RootGrid in code. -->
        <Border Grid.Row="0"
                Grid.RowSpan="2"
                x:Name="SoundBoardDropOverlay"
                Visibility="Collapsed"
                IsHitTestVisible="False"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Padding="40"
                MinWidth="420"
                MinHeight="260"
                Canvas.ZIndex="5000"
                CornerRadius="{ThemeResource VoiSee.CornerRadius.Large}"
                Background="{ThemeResource VoiSee.DropOverlayBackgroundBrush}"
                BorderBrush="{ThemeResource VoiSee.DropOverlayBorderBrush}"
                BorderThickness="2">
            <StackPanel HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Spacing="20"
                        MaxWidth="720">
                <FontIcon Glyph="&#xE898;"
                          FontFamily="Segoe MDL2 Assets"
                          FontSize="72"
                          HorizontalAlignment="Center" />
                <TextBlock Text="Drop sound files to import"
                           FontSize="28"
                           FontWeight="SemiBold"
                           TextAlignment="Center" />
                <TextBlock x:Name="SoundBoardDropOverlayDescriptionTextBlock"
                           Text="Release WAV, MP3 or OGG files to add them to the current category"
                           FontSize="16"
                           Opacity="0.78"
                           TextAlignment="Center"
                           TextWrapping="WrapWholeWords" />
            </StackPanel>
        </Border>
</Grid>
</Window>
