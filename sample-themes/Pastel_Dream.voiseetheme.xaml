<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!--
      VoiSee sample theme: Pastel Dream

      This ResourceDictionary is a complete editable VoiSee sample theme.
      Every user theme created by the application starts as an exact editable
      copy of this file. Keep x:Key names unchanged; edit only values/styles.

      ORDER:
        1. Global palette and geometry
        2. Buttons and toggle buttons
        3. Sliders
        4. Text fields and drop-down lists
        5. Lists and scene selection states
        6. Specific VoiSee panels and controls
    -->

    <!-- ================================================================ -->
    <!-- 1. GLOBAL PALETTE                                                -->
    <!-- ================================================================ -->
    <Color x:Key="VoiSee.Color.AppBackground">#FFF7F3FA</Color>
    <Color x:Key="VoiSee.Color.TitleBarBackground">#FFEFE8F5</Color>
    <Color x:Key="VoiSee.Color.TitleBarHover">#40B79CED</Color>
    <Color x:Key="VoiSee.Color.TitleBarPressed">#309B7FD1</Color>
    <Color x:Key="VoiSee.Color.PrimaryText">#FF302A36</Color>
    <Color x:Key="VoiSee.Color.SecondaryText">#B85F5668</Color>
    <Color x:Key="VoiSee.Color.Accent">#FF9B7FD1</Color>
    <Color x:Key="VoiSee.Color.PanelBackground">#CCFFFFFF</Color>
    <Color x:Key="VoiSee.Color.PanelBorder">#669E90B2</Color>
    <Color x:Key="VoiSee.Color.Danger">#FFE56B7F</Color>
    <Color x:Key="VoiSee.Color.Success">#FF63B995</Color>
    <Color x:Key="VoiSee.Color.Warning">#FFE2A85C</Color>

    <SolidColorBrush x:Key="VoiSee.AppBackgroundBrush" Color="{StaticResource VoiSee.Color.AppBackground}" />
    <SolidColorBrush x:Key="VoiSee.TitleBarBackgroundBrush" Color="{StaticResource VoiSee.Color.TitleBarBackground}" />
    <SolidColorBrush x:Key="VoiSee.TitleBarForegroundBrush" Color="{StaticResource VoiSee.Color.PrimaryText}" />
    <SolidColorBrush x:Key="VoiSee.TitleBarHoverBrush" Color="{StaticResource VoiSee.Color.TitleBarHover}" />
    <SolidColorBrush x:Key="VoiSee.TitleBarPressedBrush" Color="{StaticResource VoiSee.Color.TitleBarPressed}" />
    <SolidColorBrush x:Key="VoiSee.PanelBackgroundBrush" Color="{StaticResource VoiSee.Color.PanelBackground}" />
    <SolidColorBrush x:Key="VoiSee.PanelBorderBrush" Color="{StaticResource VoiSee.Color.PanelBorder}" />
    <SolidColorBrush x:Key="VoiSee.PrimaryTextBrush" Color="{StaticResource VoiSee.Color.PrimaryText}" />
    <SolidColorBrush x:Key="VoiSee.SecondaryTextBrush" Color="{StaticResource VoiSee.Color.SecondaryText}" />
    <SolidColorBrush x:Key="VoiSee.AccentBrush" Color="{StaticResource VoiSee.Color.Accent}" />
    <SolidColorBrush x:Key="VoiSee.DangerBrush" Color="{StaticResource VoiSee.Color.Danger}" />
    <SolidColorBrush x:Key="VoiSee.SuccessBrush" Color="{StaticResource VoiSee.Color.Success}" />
    <SolidColorBrush x:Key="VoiSee.WarningBrush" Color="{StaticResource VoiSee.Color.Warning}" />

    <!-- Geometry shared by panels and controls. -->
    <CornerRadius x:Key="VoiSee.CornerRadius.Small">4</CornerRadius>
    <CornerRadius x:Key="VoiSee.CornerRadius.Medium">10</CornerRadius>
    <CornerRadius x:Key="VoiSee.CornerRadius.Large">12</CornerRadius>
    <CornerRadius x:Key="VoiSee.CornerRadius.Button">4</CornerRadius>
    <CornerRadius x:Key="VoiSee.CornerRadius.Input">8</CornerRadius>
    <CornerRadius x:Key="VoiSee.CornerRadius.ListItem">4</CornerRadius>
    <CornerRadius x:Key="VoiSee.CornerRadius.CheckBox">0</CornerRadius>
    <Thickness x:Key="VoiSee.Thickness.ControlBorder">1</Thickness>
    <Thickness x:Key="VoiSee.Thickness.ButtonBorder">0</Thickness>
    <Thickness x:Key="VoiSee.Thickness.InputBorder">0</Thickness>
    <Thickness x:Key="VoiSee.Thickness.ComboBoxBorder">0</Thickness>
    <Thickness x:Key="VoiSee.Thickness.ListBorder">0</Thickness>
    <Thickness x:Key="VoiSee.Thickness.ListItemBorder">1</Thickness>
    <Thickness x:Key="VoiSee.Thickness.ButtonPadding">10,4</Thickness>
    <Thickness x:Key="VoiSee.Thickness.CompactButtonPadding">8,4</Thickness>
    <Thickness x:Key="VoiSee.Thickness.InputPadding">10,4</Thickness>
    <Thickness x:Key="VoiSee.Thickness.ListItemPadding">10,7</Thickness>

    <!-- Standard WinUI text/accent resources used by built-in templates. -->
    <SolidColorBrush x:Key="ApplicationPageBackgroundThemeBrush" Color="{StaticResource VoiSee.Color.AppBackground}" />
    <SolidColorBrush x:Key="TextFillColorPrimaryBrush" Color="{StaticResource VoiSee.Color.PrimaryText}" />
    <SolidColorBrush x:Key="TextFillColorSecondaryBrush" Color="{StaticResource VoiSee.Color.SecondaryText}" />
    <SolidColorBrush x:Key="AccentFillColorDefaultBrush" Color="{StaticResource VoiSee.Color.Accent}" />
    <Style x:Key="VoiSee.Style.Text.Secondary" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{ThemeResource VoiSee.SecondaryTextBrush}" />
    </Style>

    <!-- ================================================================ -->
    <!-- 2. BUTTONS AND TOGGLE BUTTONS                                    -->
    <!-- ================================================================ -->
    <!--
      Every Button state is editable. These semantic Color values feed the
      official WinUI lightweight-styling resources below, so they also apply
      to buttons created from C# in dialogs and editors.
    -->
    <Color x:Key="VoiSee.Color.ButtonBackground">#FFE7DFF0</Color>
    <Color x:Key="VoiSee.Color.ButtonBorder">#00000000</Color>
    <Color x:Key="VoiSee.Color.ButtonText">#FF302A36</Color>
    <Color x:Key="VoiSee.Color.ButtonHoverBackground">#FFDCCFE9</Color>
    <Color x:Key="VoiSee.Color.ButtonHoverBorder">#00000000</Color>
    <Color x:Key="VoiSee.Color.ButtonHoverText">#FF241F2A</Color>
    <Color x:Key="VoiSee.Color.ButtonPressedBackground">#FFD1C0E1</Color>
    <Color x:Key="VoiSee.Color.ButtonPressedBorder">#00000000</Color>
    <Color x:Key="VoiSee.Color.ButtonPressedText">#FF241F2A</Color>
    <Color x:Key="VoiSee.Color.ButtonDisabledBackground">#FFF0EBF3</Color>
    <Color x:Key="VoiSee.Color.ButtonDisabledBorder">#00000000</Color>
    <Color x:Key="VoiSee.Color.ButtonDisabledText">#665F5668</Color>

    <!-- Backward-compatible aliases retained for themes created by 10.1.0-10.1.2. -->
    <StaticResource x:Key="VoiSee.Color.ButtonHover" ResourceKey="VoiSee.Color.ButtonHoverBackground" />
    <StaticResource x:Key="VoiSee.Color.ButtonPressed" ResourceKey="VoiSee.Color.ButtonPressedBackground" />

    <SolidColorBrush x:Key="VoiSee.ButtonBackgroundBrush" Color="{StaticResource VoiSee.Color.ButtonBackground}" />
    <SolidColorBrush x:Key="VoiSee.ButtonBorderBrush" Color="{StaticResource VoiSee.Color.ButtonBorder}" />
    <SolidColorBrush x:Key="VoiSee.ButtonTextBrush" Color="{StaticResource VoiSee.Color.ButtonText}" />
    <SolidColorBrush x:Key="VoiSee.ButtonHoverBackgroundBrush" Color="{StaticResource VoiSee.Color.ButtonHoverBackground}" />
    <SolidColorBrush x:Key="VoiSee.ButtonHoverBorderBrush" Color="{StaticResource VoiSee.Color.ButtonHoverBorder}" />
    <SolidColorBrush x:Key="VoiSee.ButtonHoverTextBrush" Color="{StaticResource VoiSee.Color.ButtonHoverText}" />
    <SolidColorBrush x:Key="VoiSee.ButtonPressedBackgroundBrush" Color="{StaticResource VoiSee.Color.ButtonPressedBackground}" />
    <SolidColorBrush x:Key="VoiSee.ButtonPressedBorderBrush" Color="{StaticResource VoiSee.Color.ButtonPressedBorder}" />
    <SolidColorBrush x:Key="VoiSee.ButtonPressedTextBrush" Color="{StaticResource VoiSee.Color.ButtonPressedText}" />
    <SolidColorBrush x:Key="VoiSee.ButtonDisabledBackgroundBrush" Color="{StaticResource VoiSee.Color.ButtonDisabledBackground}" />
    <SolidColorBrush x:Key="VoiSee.ButtonDisabledBorderBrush" Color="{StaticResource VoiSee.Color.ButtonDisabledBorder}" />
    <SolidColorBrush x:Key="VoiSee.ButtonDisabledTextBrush" Color="{StaticResource VoiSee.Color.ButtonDisabledText}" />

    <!-- Official WinUI Button lightweight-styling resource names. -->
    <SolidColorBrush x:Key="ButtonBackground" Color="{StaticResource VoiSee.Color.ButtonBackground}" />
    <SolidColorBrush x:Key="ButtonBorderBrush" Color="{StaticResource VoiSee.Color.ButtonBorder}" />
    <SolidColorBrush x:Key="ButtonForeground" Color="{StaticResource VoiSee.Color.ButtonText}" />
    <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="{StaticResource VoiSee.Color.ButtonHoverBackground}" />
    <SolidColorBrush x:Key="ButtonBorderBrushPointerOver" Color="{StaticResource VoiSee.Color.ButtonHoverBorder}" />
    <SolidColorBrush x:Key="ButtonForegroundPointerOver" Color="{StaticResource VoiSee.Color.ButtonHoverText}" />
    <SolidColorBrush x:Key="ButtonBackgroundPressed" Color="{StaticResource VoiSee.Color.ButtonPressedBackground}" />
    <SolidColorBrush x:Key="ButtonBorderBrushPressed" Color="{StaticResource VoiSee.Color.ButtonPressedBorder}" />
    <SolidColorBrush x:Key="ButtonForegroundPressed" Color="{StaticResource VoiSee.Color.ButtonPressedText}" />
    <SolidColorBrush x:Key="ButtonBackgroundDisabled" Color="{StaticResource VoiSee.Color.ButtonDisabledBackground}" />
    <SolidColorBrush x:Key="ButtonBorderBrushDisabled" Color="{StaticResource VoiSee.Color.ButtonDisabledBorder}" />
    <SolidColorBrush x:Key="ButtonForegroundDisabled" Color="{StaticResource VoiSee.Color.ButtonDisabledText}" />

    <Style x:Key="VoiSee.Style.Button" TargetType="Button">
        <Setter Property="MinHeight" Value="34" />
        <Setter Property="Padding" Value="{ThemeResource VoiSee.Thickness.ButtonPadding}" />
        <Setter Property="CornerRadius" Value="{ThemeResource VoiSee.CornerRadius.Button}" />
        <Setter Property="Background" Value="{ThemeResource VoiSee.ButtonBackgroundBrush}" />
        <Setter Property="Foreground" Value="{ThemeResource VoiSee.ButtonTextBrush}" />
        <Setter Property="BorderBrush" Value="{ThemeResource VoiSee.ButtonBorderBrush}" />
        <Setter Property="BorderThickness" Value="{ThemeResource VoiSee.Thickness.ButtonBorder}" />
    </Style>
    <!-- All unstyled/dynamically created buttons inherit the same editable theme. -->
    <Style TargetType="Button" BasedOn="{StaticResource VoiSee.Style.Button}" />

    <Style x:Key="VoiSee.Style.Button.Compact" TargetType="Button" BasedOn="{StaticResource VoiSee.Style.Button}">
        <Setter Property="MinHeight" Value="30" />
        <Setter Property="Padding" Value="{ThemeResource VoiSee.Thickness.CompactButtonPadding}" />
    </Style>
    <Style x:Key="VoiSee.Style.Button.Transport" TargetType="Button" BasedOn="{StaticResource VoiSee.Style.Button}">
        <Setter Property="MinHeight" Value="42" />
        <Setter Property="CornerRadius" Value="{ThemeResource VoiSee.CornerRadius.Button}" />
    </Style>
    <Style x:Key="VoiSee.Style.Button.Danger" TargetType="Button" BasedOn="{StaticResource VoiSee.Style.Button}" />

    <!-- ToggleButton normal states reuse the complete Button palette. -->
    <Color x:Key="VoiSee.Color.ToggleCheckedBackground">#FFCDBCE2</Color>
    <Color x:Key="VoiSee.Color.ToggleCheckedBorder">#00000000</Color>
    <Color x:Key="VoiSee.Color.ToggleCheckedText">#FF302A36</Color>
