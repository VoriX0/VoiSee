    <Color x:Key="VoiSee.Color.ToggleCheckedHoverBorder">#00000000</Color>
    <Color x:Key="VoiSee.Color.ToggleCheckedHoverText">#FF241F2A</Color>
    <Color x:Key="VoiSee.Color.ToggleCheckedPressedBackground">#FFB397CF</Color>
    <Color x:Key="VoiSee.Color.ToggleCheckedPressedBorder">#00000000</Color>
    <Color x:Key="VoiSee.Color.ToggleCheckedPressedText">#FF241F2A</Color>

    <SolidColorBrush x:Key="ToggleButtonBackground" Color="{StaticResource VoiSee.Color.ButtonBackground}" />
    <SolidColorBrush x:Key="ToggleButtonBorderBrush" Color="{StaticResource VoiSee.Color.ButtonBorder}" />
    <SolidColorBrush x:Key="ToggleButtonForeground" Color="{StaticResource VoiSee.Color.ButtonText}" />
    <SolidColorBrush x:Key="ToggleButtonBackgroundPointerOver" Color="{StaticResource VoiSee.Color.ButtonHoverBackground}" />
    <SolidColorBrush x:Key="ToggleButtonBorderBrushPointerOver" Color="{StaticResource VoiSee.Color.ButtonHoverBorder}" />
    <SolidColorBrush x:Key="ToggleButtonForegroundPointerOver" Color="{StaticResource VoiSee.Color.ButtonHoverText}" />
    <SolidColorBrush x:Key="ToggleButtonBackgroundPressed" Color="{StaticResource VoiSee.Color.ButtonPressedBackground}" />
    <SolidColorBrush x:Key="ToggleButtonBorderBrushPressed" Color="{StaticResource VoiSee.Color.ButtonPressedBorder}" />
    <SolidColorBrush x:Key="ToggleButtonForegroundPressed" Color="{StaticResource VoiSee.Color.ButtonPressedText}" />
    <SolidColorBrush x:Key="ToggleButtonBackgroundDisabled" Color="{StaticResource VoiSee.Color.ButtonDisabledBackground}" />
    <SolidColorBrush x:Key="ToggleButtonBorderBrushDisabled" Color="{StaticResource VoiSee.Color.ButtonDisabledBorder}" />
    <SolidColorBrush x:Key="ToggleButtonForegroundDisabled" Color="{StaticResource VoiSee.Color.ButtonDisabledText}" />
    <SolidColorBrush x:Key="ToggleButtonBackgroundChecked" Color="{StaticResource VoiSee.Color.ToggleCheckedBackground}" />
    <SolidColorBrush x:Key="ToggleButtonBorderBrushChecked" Color="{StaticResource VoiSee.Color.ToggleCheckedBorder}" />
    <SolidColorBrush x:Key="ToggleButtonForegroundChecked" Color="{StaticResource VoiSee.Color.ToggleCheckedText}" />
    <SolidColorBrush x:Key="ToggleButtonBackgroundCheckedPointerOver" Color="{StaticResource VoiSee.Color.ToggleCheckedHoverBackground}" />
    <SolidColorBrush x:Key="ToggleButtonBorderBrushCheckedPointerOver" Color="{StaticResource VoiSee.Color.ToggleCheckedHoverBorder}" />
    <SolidColorBrush x:Key="ToggleButtonForegroundCheckedPointerOver" Color="{StaticResource VoiSee.Color.ToggleCheckedHoverText}" />
    <SolidColorBrush x:Key="ToggleButtonBackgroundCheckedPressed" Color="{StaticResource VoiSee.Color.ToggleCheckedPressedBackground}" />
    <SolidColorBrush x:Key="ToggleButtonBorderBrushCheckedPressed" Color="{StaticResource VoiSee.Color.ToggleCheckedPressedBorder}" />
    <SolidColorBrush x:Key="ToggleButtonForegroundCheckedPressed" Color="{StaticResource VoiSee.Color.ToggleCheckedPressedText}" />
    <SolidColorBrush x:Key="ToggleButtonBackgroundCheckedDisabled" Color="{StaticResource VoiSee.Color.ButtonDisabledBackground}" />
    <SolidColorBrush x:Key="ToggleButtonBorderBrushCheckedDisabled" Color="{StaticResource VoiSee.Color.ButtonDisabledBorder}" />
    <SolidColorBrush x:Key="ToggleButtonForegroundCheckedDisabled" Color="{StaticResource VoiSee.Color.ButtonDisabledText}" />

    <Style x:Key="VoiSee.Style.ToggleButton" TargetType="ToggleButton">
        <Setter Property="MinHeight" Value="34" />
        <Setter Property="Padding" Value="{ThemeResource VoiSee.Thickness.ButtonPadding}" />
        <Setter Property="CornerRadius" Value="{ThemeResource VoiSee.CornerRadius.Button}" />
        <Setter Property="Background" Value="{ThemeResource VoiSee.ButtonBackgroundBrush}" />
        <Setter Property="Foreground" Value="{ThemeResource VoiSee.ButtonTextBrush}" />
        <Setter Property="BorderBrush" Value="{ThemeResource VoiSee.ButtonBorderBrush}" />
        <Setter Property="BorderThickness" Value="{ThemeResource VoiSee.Thickness.ButtonBorder}" />
    </Style>
    <Style TargetType="ToggleButton" BasedOn="{StaticResource VoiSee.Style.ToggleButton}" />

    <!-- ================================================================ -->
    <!-- 3. SLIDERS                                                       -->
    <!-- ================================================================ -->
    <!-- Track, filled track, thumb and all pointer/pressed states. -->
    <Color x:Key="VoiSee.Color.SliderTrack">#55B9AEC2</Color>
    <Color x:Key="VoiSee.Color.SliderTrackHover">#77A99BB8</Color>
    <Color x:Key="VoiSee.Color.SliderTrackPressed">#999888AA</Color>
    <Color x:Key="VoiSee.Color.SliderTrackDisabled">#339E95A5</Color>
    <Color x:Key="VoiSee.Color.SliderFill">#FFB79CED</Color>
    <Color x:Key="VoiSee.Color.SliderFillHover">#FF9B7FD1</Color>
    <Color x:Key="VoiSee.Color.SliderFillPressed">#FF7F65B5</Color>
    <Color x:Key="VoiSee.Color.SliderFillDisabled">#66B79CED</Color>
    <Color x:Key="VoiSee.Color.SliderThumb">#FF7F65B5</Color>
