    <SolidColorBrush x:Key="VoiSee.SliderTrackBrush" Color="{StaticResource VoiSee.Color.SliderTrack}" />
    <SolidColorBrush x:Key="VoiSee.SliderFillBrush" Color="{StaticResource VoiSee.Color.SliderFill}" />
    <SolidColorBrush x:Key="VoiSee.SliderThumbBrush" Color="{StaticResource VoiSee.Color.SliderThumb}" />
    <SolidColorBrush x:Key="VoiSee.SliderThumbHoverBrush" Color="{StaticResource VoiSee.Color.SliderThumbHover}" />

    <!-- Official WinUI Slider lightweight-styling resource names. -->
    <SolidColorBrush x:Key="SliderTrackFill" Color="{StaticResource VoiSee.Color.SliderTrack}" />
    <SolidColorBrush x:Key="SliderTrackFillPointerOver" Color="{StaticResource VoiSee.Color.SliderTrackHover}" />
    <SolidColorBrush x:Key="SliderTrackFillPressed" Color="{StaticResource VoiSee.Color.SliderTrackPressed}" />
    <SolidColorBrush x:Key="SliderTrackFillDisabled" Color="{StaticResource VoiSee.Color.SliderTrackDisabled}" />
    <SolidColorBrush x:Key="SliderTrackValueFill" Color="{StaticResource VoiSee.Color.SliderFill}" />
    <SolidColorBrush x:Key="SliderTrackValueFillPointerOver" Color="{StaticResource VoiSee.Color.SliderFillHover}" />
    <SolidColorBrush x:Key="SliderTrackValueFillPressed" Color="{StaticResource VoiSee.Color.SliderFillPressed}" />
