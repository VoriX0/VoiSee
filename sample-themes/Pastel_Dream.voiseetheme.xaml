    <SolidColorBrush x:Key="SliderThumbBackground" Color="{StaticResource VoiSee.Color.SliderThumb}" />
    <SolidColorBrush x:Key="SliderThumbBackgroundPointerOver" Color="{StaticResource VoiSee.Color.SliderThumbHover}" />
    <SolidColorBrush x:Key="SliderThumbBackgroundPressed" Color="{StaticResource VoiSee.Color.SliderThumbPressed}" />
    <SolidColorBrush x:Key="SliderThumbBackgroundDisabled" Color="{StaticResource VoiSee.Color.SliderThumbDisabled}" />
    <SolidColorBrush x:Key="SliderThumbBorderBrush" Color="{StaticResource VoiSee.Color.SliderThumbBorder}" />
    <SolidColorBrush x:Key="SliderOuterThumbBackground" Color="{StaticResource VoiSee.Color.PanelBackground}" />

    <Style x:Key="VoiSee.Style.Slider" TargetType="Slider">
        <Setter Property="MinHeight" Value="32" />
        <Setter Property="Background" Value="{ThemeResource VoiSee.SliderTrackBrush}" />
        <Setter Property="Foreground" Value="{ThemeResource VoiSee.SliderFillBrush}" />
    </Style>
    <Style TargetType="Slider" BasedOn="{StaticResource VoiSee.Style.Slider}" />

    <!-- ================================================================ -->
