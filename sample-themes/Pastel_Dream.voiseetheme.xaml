    <Color x:Key="VoiSee.Color.InputText">#FF302A36</Color>
    <Color x:Key="VoiSee.Color.InputHoverBackground">#FFF9F4FC</Color>
    <Color x:Key="VoiSee.Color.InputHoverBorder">#00000000</Color>
    <Color x:Key="VoiSee.Color.InputHoverText">#FF241F2A</Color>
    <Color x:Key="VoiSee.Color.InputFocusedBackground">#FFFFFFFF</Color>
    <Color x:Key="VoiSee.Color.InputFocusedBorder">#00000000</Color>
